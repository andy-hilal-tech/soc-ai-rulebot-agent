  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Audit.Command Execution Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "19250"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Command&quot;) LIKE '%ls%-recurse%' OR LOWER(&quot;Command&quot;) LIKE '%get-childitem%-recurse%' OR LOWER(&quot;Command&quot;) LIKE '%gci%-recurse%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20LIKE%20'%25ls%25-recurse%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25get-childitem%25-recurse%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25gci%25-recurse%25'|%5B%22LOWER(%5C%22Command%5C%22)%20LIKE%20'%25ls%25-recurse%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25get-childitem%25-recurse%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25gci%25-recurse%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
