          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(LOWER(&quot;Command&quot;) LIKE '%clear-eventlog %' or LOWER(&quot;Command&quot;) LIKE '%remove-eventlog %' or LOWER(&quot;Command&quot;) LIKE '%limit-eventlog %' or LOWER(&quot;Command&quot;) LIKE '%clear-winevent %')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(%22Command%22)%20LIKE%20'%25clear-eventlog%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25remove-eventlog%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25limit-eventlog%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25clear-winevent%20%25')|%5B%22(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25clear-eventlog%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25remove-eventlog%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25limit-eventlog%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25clear-winevent%20%25')%22%5D"
            },
