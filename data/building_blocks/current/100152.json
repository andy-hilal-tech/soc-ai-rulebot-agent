  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "IPProtocol_Test",
            "uid": "0",
            "id": "2"
          },
          "text": [
            "when the IP protocol is one of the following <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>ICMP</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "ICMP"
            }
          ]
        },
        {
          "_$": {
            "name": "AttackContext_Test",
            "uid": "1",
            "id": "25",
            "negate": "true"
          },
          "text": [
            "when the flow context is <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Local to Local</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "l2l"
            }
          ]
        },
        {
          "_$": {
            "name": "IcmpType",
            "uid": "3",
            "id": "212",
            "negate": "true"
          },
          "text": [
            "when the ICMP type is any of <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Echo Reply, Echo, Destination Unreachable, Time Exceeded</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getIcmpTypes",
              "value": "0, 8, 3, 11"
            }
          ]
        }
      ]
    }
