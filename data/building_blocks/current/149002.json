            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Command&quot;) LIKE '%get-process%' AND LOWER(&quot;Command&quot;) LIKE '%.Description%' AND LOWER(&quot;Command&quot;) LIKE '%-like%' AND (LOWER(&quot;Command&quot;) LIKE '%\\*virus*\\%' OR LOWER(&quot;Command&quot;) LIKE '%\\*carbonblack*\\%' OR LOWER(&quot;Command&quot;) LIKE '%\\*defender*\\%' OR LOWER(&quot;Command&quot;) LIKE '%\\*cylance*\\%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20LIKE%20'%25get-process%25'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25.Description%25'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25-like%25'%20AND%20(LOWER(%22Command%22)%20LIKE%20'%25%5C*virus*%5C%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25%5C*carbonblack*%5C%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25%5C*defender*%5C%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25%5C*cylance*%5C%25')|%5B%22LOWER(%5C%22Command%5C%22)%20LIKE%20'%25get-process%25'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25.Description%25'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25-like%25'%20AND%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5C*virus*%5C%5C%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5C*carbonblack*%5C%5C%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5C*defender*%5C%5C%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5C*cylance*%5C%5C%25')%22%5D"
