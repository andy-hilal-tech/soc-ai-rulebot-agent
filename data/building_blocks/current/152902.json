  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.File Created, System.Successful File Modification</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8028, 8014"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "2",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>File Directory (custom) is any of \\Windows\\System32\\Tasks</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "File DirectoryEQany\\Windows\\System32\\Tasks"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(LOWER(&quot;Process File File Path&quot;) LIKE'%\\appdata\\%' or LOWER(&quot;Process File File Path&quot;) LIKE'%c:\\perflogs%' or LOWER(&quot;Process File File Path&quot;) LIKE'%\\windows\\system32\\config\\systemprofile%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(%22Process%20Path%22)%20LIKE'%25%5Cappdata%5C%25'%20or%20LOWER(%22Process%20Path%22)%20LIKE'%25c%3A%5Cperflogs%25'%20or%20LOWER(%22Process%20Path%22)%20LIKE'%25%5Cwindows%5Csystem32%5Cconfig%5Csystemprofile%25')|%5B%22(LOWER(%5C%22Process%20Path%5C%22)%20LIKE'%25%5C%5Cappdata%5C%5C%25'%20or%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE'%25c%3A%5C%5Cperflogs%25'%20or%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE'%25%5C%5Cwindows%5C%5Csystem32%5C%5Cconfig%5C%5Csystemprofile%25')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
