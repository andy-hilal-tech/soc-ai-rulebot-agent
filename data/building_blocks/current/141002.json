        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(CONCAT(&quot;Registry Key&quot;, '\\', &quot;Registry Value Name&quot;)) MATCHES '.*\\\\((folder|ms-settings|launcher.systemsettings|ms-windows-store|appx82a6gwre4fdg3bt635tn5ctqjf8msdd2)\\\\(shell\\\\open\\\\command|curver|url protocol)|environment\\\\(windir|cor_profiler)|microsoft\\\\windows nt\\\\currentversion\\\\icm\\\\calibration\\\\displaycalibrator).*'</a> AQL filter query"
