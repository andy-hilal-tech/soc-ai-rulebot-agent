          "parameter": [
            {
              "id": "1",
              "value": "LOWER(CONCAT(%22Registry%20Key%22,%20'%5C',%20%22Registry%20Value%20Name%22))%20MATCHES%20'.*%5C%5C((folder%7Cms-settings%7Clauncher.systemsettings%7Cms-windows-store%7Cappx82a6gwre4fdg3bt635tn5ctqjf8msdd2)%5C%5C(shell%5C%5Copen%5C%5Ccommand%7Ccurver%7Curl%20protocol)%7Cenvironment%5C%5C(windir%7Ccor_profiler)%7Cmicrosoft%5C%5Cwindows%20nt%5C%5Ccurrentversion%5C%5Cicm%5C%5Ccalibration%5C%5Cdisplaycalibrator).*'|%5B%22LOWER(CONCAT(%5C%22Registry%20Key%5C%22,%20'%5C%5C',%20%5C%22Registry%20Value%20Name%5C%22))%20MATCHES%20'.*%5C%5C%5C%5C((folder%7Cms-settings%7Clauncher.systemsettings%7Cms-windows-store%7Cappx82a6gwre4fdg3bt635tn5ctqjf8msdd2)%5C%5C%5C%5C(shell%5C%5C%5C%5Copen%5C%5C%5C%5Ccommand%7Ccurver%7Curl%20protocol)%7Cenvironment%5C%5C%5C%5C(windir%7Ccor_profiler)%7Cmicrosoft%5C%5C%5C%5Cwindows%20nt%5C%5C%5C%5Ccurrentversion%5C%5C%5C%5Cicm%5C%5C%5C%5Ccalibration%5C%5C%5C%5Cdisplaycalibrator).*'%22%5D"
            },
