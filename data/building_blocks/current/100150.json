            }
          ]
        },
        {
          "_$": {
            "name": "BytePacketCount",
            "uid": "2",
            "id": "201"
          },
          "text": [
            "when the <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>source</a> <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>packets</a> is <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>equal to</a> <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>1</a>"
          ],
          "parameter": [
            {
