          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>File Directory (custom) matches any of expressions (?i)\\\\system32(\\\\|$)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "File DirectoryREXany(?i)\\\\system32(\\\\|$)"
            },
            {
              "id": "2",
