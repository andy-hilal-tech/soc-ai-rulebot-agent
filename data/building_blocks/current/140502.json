          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "2",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
