            "name": "ArielFilterTest",
            "uid": "0",
            "id": "316",
            "negate": "false"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>File Directory (custom) does not match any of expressions (?i)\\w:\\\\windows\\\\system32(\\\\|$)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "File DirectoryNREXany(?i)\\w:\\\\windows\\\\system32(\\\\|$)"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
