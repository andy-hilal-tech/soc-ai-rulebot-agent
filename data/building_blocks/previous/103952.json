          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "2",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>(5000584) Failure Audit: Kerberos pre-authentication failed, (5000585) Failure Audit: A Kerberos authentication ticket request failed, (5000581) Failure Audit: A Kerberos authentication ticket (TGT) was rejected</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5000584,             5000585,             5000581"
            }
          ]
        },
        {
          "_$": {
            "name": "PropertyRegex",
            "uid": "3",
            "id": "225"
          },
          "text": [
            "when any of <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Status Code (custom)</a> match <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>0x17</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventDatabaseFields",
              "value": "Status Code"
            },
            {
              "id": "2",
              "value": "0x17"
            }
          ]
        }
      ]
    }
