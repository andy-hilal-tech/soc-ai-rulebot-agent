        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(LOWER(&quot;Command&quot;) LIKE '*/create* *regsvr32.exe*') or (LOWER(&quot;Command&quot;) LIKE '%wscript%' or LOWER(&quot;Command&quot;) LIKE '%vbscript%' or LOWER(&quot;Command&quot;) LIKE '%cscript%' or LOWER(&quot;Command&quot;) LIKE '%wmic %' or LOWER(&quot;Command&quot;) LIKE '%wmic.exe%' or LOWER(&quot;Command&quot;) LIKE '%regsvr32.exe%' or LOWER(&quot;Command&quot;) LIKE '%powershell%' or LOWER(&quot;Command&quot;) LIKE '%\\appdata\\%') or (LOWER(&quot;Command&quot;) LIKE '%/create%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(%22Command%22)%20LIKE%20'*%2Fcreate*%20*regsvr32.exe*')%20or%20(LOWER(%22Command%22)%20LIKE%20'%25wscript%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25vbscript%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25cscript%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25wmic%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25wmic.exe%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25regsvr32.exe%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25powershell%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25%5Cappdata%5C%25')%20or%20(LOWER(%22Command%22)%20LIKE%20'%25%2Fcreate%25')|%5B%22(LOWER(%5C%22Command%5C%22)%20LIKE%20'*%2Fcreate*%20*regsvr32.exe*')%20or%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25wscript%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25vbscript%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25cscript%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25wmic%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25wmic.exe%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25regsvr32.exe%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25powershell%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5Cappdata%5C%5C%25')%20or%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%2Fcreate%25')%20%22%5D"
