    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "2",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>System.Successful Registry Modification, System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8012, 8110"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "3",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>2</a> events are seen with the same <a href='javascript:editParameter(\"3\", \"3\")' class='dynamic'>Object Name Lowercase (custom), Machine Identifier (custom)</a> and different <a href='javascript:editParameter(\"3\", \"4\")' class='dynamic'>Low Level Category</a> in <a href='javascript:editParameter(\"3\", \"5\")' class='dynamic'>2</a> <a href='javascript:editParameter(\"3\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "2"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "Object Name Lowercase, Machine Identifier"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "category"
            },
            {
              "id": "5",
              "value": "2"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        }
      ]
    }
