        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Account Name (custom) is any of $</a>"
