        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(LOWER(&quot;registry key&quot;) MATCHES ('.*?(\\\\atctl).*')  or LOWER(&quot;registry value data&quot;) MATCHES '.*?(\\\\atctl).*') or  (LOWER(&quot;registry key&quot;) MATCHES '.*?(4d36e97d-e325-11ce-bfc1-08002be10318).*')  or LOWER(&quot;registry value data&quot;) MATCHES '.*?(4d36e97d-e325-11ce-bfc1-08002be10318).*') ) or  (LOWER(&quot;registry key&quot;) MATCHES '.*?(4d36e96a-e325-11ce-bfc1-08002be10318).*')  or LOWER(&quot;registry value data&quot;) MATCHES '.*?(4d36e96a-e325-11ce-bfc1-08002be10318).*') ) or  (LOWER(&quot;registry key&quot;) MATCHES '.*?(4d36e969-e325-11ce-bfc1-08002be10318).*')  or LOWER(&quot;registry value data&quot;) MATCHES '.*?(4d36e969-e325-11ce-bfc1-08002be10318).*') ) or  (LOWER(&quot;registry key&quot;) MATCHES '.*?(screensaver).*')  or LOWER(&quot;registry value data&quot;) MATCHES '.*?(screensaver).*') ) or  (LOWER(&quot;registry key&quot;) MATCHES '.*?(49cbb1c7-97d1-485a-9ec1-a26065633066).*')  or LOWER(&quot;registry value data&quot;) MATCHES '.*?(49cbb1c7-97d1-485a-9ec1-a26065633066).*') ) or  (LOWER(&quot;registry key&quot;) MATCHES '.*?(zonepolicy).*')  or LOWER(&quot;registry value data&quot;) MATCHES '.*?(zonepolicy).*') ) or (LOWER(&quot;registry key&quot;) MATCHES '.*?(59031a47-3f72-44a7-80c5-5595fe6b30ee).*')  or LOWER(&quot;registry value data&quot;) MATCHES '.*?(59031a47-3f72-44a7-80c5-5595fe6b30ee).*') ) or (LOWER(&quot;registry key&quot;) MATCHES ('.*?(windows\\.wsqmcons).*')  or LOWER(&quot;registry value data&quot;) MATCHES ('.*?(windows\\.wsqmcons).*') )</a> AQL filter query"
          ],
