  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "0",
            "id": "46"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"0\", \"2\")' class='dynamic'>BB:DeviceDefinition: Operating System</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "73022aff-8dd2-4bc0-b316-d86bd7e3ac7f"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "3",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>System.Successful Registry Modification, Audit.Object Access Success, System.Information</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8012, 19081, 8052"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>&quot;Registry Key&quot; is not NULL OR &quot;Registry Value Data&quot; is not NULL</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
