            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) IN ('plink.exe', 'socat.exe', 'stunnel.exe', 'httptunnel.exe')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20IN%20('plink.exe'%2C%20'socat.exe'%2C%20'stunnel.exe'%2C%20'httptunnel.exe')|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20IN%20('plink.exe'%2C%20'socat.exe'%2C%20'stunnel.exe'%2C%20'httptunnel.exe')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
