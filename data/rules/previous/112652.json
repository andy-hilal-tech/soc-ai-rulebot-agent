  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001828) Process Create, (5000862) Success Audit: A new process has been created, (5001832) RegistryEvent (Value Set), (5001108) Success Audit: A network share object was accessed, (5002197) A service was installed in a system</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828,                                                                               5000862,                                                                               5001832,                                                                               5001108,                                                                               5002197"
            }
          ]
        },
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "2",
            "id": "46"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>BB:BehaviorDefinition: PsExec Process Observed, PsExec Process Masquerading</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "e13363dd-1fd5-49d9-a8d6-b59be0831ce9, 50800f7b-f488-4c61-b0b7-bc472948f21a"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "3",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>Source IP</a> are contained in <a href='javascript:editParameter(\"3\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"4\")' class='dynamic'>Compromised Hosts - IP</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "sourceIP"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "69"
            }
          ]
        }
      ]
    }
  ],
