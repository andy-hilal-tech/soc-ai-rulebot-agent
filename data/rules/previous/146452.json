  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success, Audit.Command Execution Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 19250"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Command&quot;) LIKE '%history -c%' OR LOWER(&quot;Command&quot;) LIKE '%clear logging%' OR LOWER(&quot;Command&quot;) LIKE '%clear history%' OR LOWER(&quot;Command&quot;) LIKE '%clear-history%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20LIKE%20'%25history%20-c%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25clear%20logging%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25clear%20history%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25clear-history%25'|%5B%22LOWER(%5C%22Command%5C%22)%20LIKE%20'%25history%20-c%25'%22,%22OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25clear%20logging%25'%22,%22OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25clear%20history%25'%22,%22OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25clear-history%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
