      "test": [
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "0",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>devicetype=12 AND (&quot;Event ID&quot;=4624 AND &quot;Logon Type&quot;=10 AND LOWER(UTF8(payload)) LIKE '%-%') </a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "devicetype%3D12%20AND%20%28%22Event%20ID%22%3D4624%20AND%20%22Logon%20Type%22%3D10%20AND%20LOWER%28UTF8%28payload%29%29%20LIKE%20%27%25-%25%27%29%20|%5B%22devicetype%3D12%20AND%20%28%22Event%20ID%22%3D4624%20AND%20%22Logon%20Type%22%3D10%20AND%20LOWER%28UTF8%28payload%29%29%20LIKE%20%27%25-%25%27%29%20%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "SrcHost_Test",
            "uid": "1",
            "id": "8",
            "negate": "true"
          },
          "text": [
            "when the source IP is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>10.0.0.0/8, 127.0.0.0/8, 172.16.0.0/12, ::1/128, 192.168.0.0/16, 169.254.0.0/16, fc00::/7, fe80::/10</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "10.0.0.0/8, 127.0.0.0/8, 172.16.0.0/12, ::1/128, 192.168.0.0/16, 169.254.0.0/16, fc00::/7, fe80::/10"
            }
          ]
        }
      ]
    }
