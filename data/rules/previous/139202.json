  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Process Name&quot;) MATCHES '(cmd|powershell|rundll32|scrcons|(w|c)script|(ba)?sh)\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20MATCHES%20'(cmd%7Cpowershell%7Crundll32%7Cscrcons%7C(w%7Cc)script%7C(ba)%3Fsh)%5C.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20MATCHES%20'(cmd%7Cpowershell%7Crundll32%7Cscrcons%7C(w%7Cc)script%7C(ba)%3Fsh)%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Parent Process Name&quot;) MATCHES '(spoolsv|mshta|wscript|wuapp|taskeng|rundll32|regsvr32|iexplore|winword|powerpnt|excel|access|notepad|outlook|calc|iexplore|mspub|psexesvc|wsmprovhost|wmiprvse|visio|acrord\\d\\d)\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Parent%20Process%20Name%22)%20MATCHES%20'(spoolsv%7Cmshta%7Cwscript%7Cwuapp%7Ctaskeng%7Crundll32%7Cregsvr32%7Ciexplore%7Cwinword%7Cpowerpnt%7Cexcel%7Caccess%7Cnotepad%7Coutlook%7Ccalc%7Ciexplore%7Cmspub%7Cpsexesvc%7Cwsmprovhost%7Cwmiprvse%7Cvisio%7Cacrord%5Cd%5Cd)%5C.exe'|%5B%22LOWER(%5C%22Parent%20Process%20Name%5C%22)%20MATCHES%20'(spoolsv%7Cmshta%7Cwscript%7Cwuapp%7Ctaskeng%7Crundll32%7Cregsvr32%7Ciexplore%7Cwinword%7Cpowerpnt%7Cexcel%7Caccess%7Cnotepad%7Coutlook%7Ccalc%7Ciexplore%7Cmspub%7Cpsexesvc%7Cwsmprovhost%7Cwmiprvse%7Cvisio%7Cacrord%5C%5Cd%5C%5Cd)%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
