    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "5",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "0",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>System.File Created, Audit.Object Load Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8028, 19247"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>File Extension (custom) is any of dll</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "File ExtensionEQanydll"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "4",
            "id": "316",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>Process Name (custom) is any of [backgroundTaskHost.exe or cleanmgr.exe]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process NameEQanybackgroundTaskHost.exe�cleanmgr.exe"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "1",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>2</a> events are seen with the same <a href='javascript:editParameter(\"1\", \"3\")' class='dynamic'>Filename (custom)</a> and different <a href='javascript:editParameter(\"1\", \"4\")' class='dynamic'>Low Level Category</a> in <a href='javascript:editParameter(\"1\", \"5\")' class='dynamic'>2</a> <a href='javascript:editParameter(\"1\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
