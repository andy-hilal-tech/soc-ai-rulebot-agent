  "rule_name": "GAC DLL Loaded Via Office Application",
  "object_type": "rule",
  "group": "Turla, Endpoint",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
