  "created": "2023-02-16T11:37:33.289Z",
  "modified": "2024-07-21T12:38:20.965Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001844) Image loaded</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001844"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) MATCHES '(excel|mspub|onenote|onenoteim|outlook|powerpnt|winword)\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20MATCHES%20'(excel%7Cmspub%7Conenote%7Conenoteim%7Coutlook%7Cpowerpnt%7Cwinword)%5C.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20MATCHES%20'(excel%7Cmspub%7Conenote%7Conenoteim%7Coutlook%7Cpowerpnt%7Cwinword)%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;File Directory&quot;) MATCHES 'c:\\\\windows\\\\microsoft\\.net\\\\assembly\\\\gac_msil.*'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22File%20Directory%22)%20MATCHES%20'c%3A%5C%5Cwindows%5C%5Cmicrosoft%5C.net%5C%5Cassembly%5C%5Cgac_msil.*'|%5B%22LOWER(%5C%22File%20Directory%5C%22)%20MATCHES%20'c%3A%5C%5C%5C%5Cwindows%5C%5C%5C%5Cmicrosoft%5C%5C.net%5C%5C%5C%5Cassembly%5C%5C%5C%5Cgac_msil.*'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
