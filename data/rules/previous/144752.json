            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) == 'rundll32.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20%3D%3D%20'rundll32.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20%3D%3D%20'rundll32.exe'%22%5D"
