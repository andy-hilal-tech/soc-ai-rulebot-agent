          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Parent Process Full Full Name&quot;) MATCHES '(winword|excel|msaccess|lsass|taskeng|winlogon|schtask|regsvr32|wmiprvse|wsmprovhost)\\.exe'</a> AQL filter query"
