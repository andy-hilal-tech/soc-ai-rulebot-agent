          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001828) Process Create</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>IMP Hash (custom) is any of [159D56D406180A332FBC99290F30700E or C1E59519B5E5D84AF07AFA6F5A8625F1]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "IMP HashEQany159D56D406180A332FBC99290F30700E�C1E59519B5E5D84AF07AFA6F5A8625F1"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Process Name NOT IMATCHES 'PsExec(\\d\\d)?\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Process%20Name%22%20NOT%20IMATCHES%20'PsExec(%5Cd%5Cd)%3F%5C.exe'|%5B%22%5C%22Process%20Name%5C%22%20NOT%20IMATCHES%20'PsExec(%5C%5Cd%5C%5Cd)%3F%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
