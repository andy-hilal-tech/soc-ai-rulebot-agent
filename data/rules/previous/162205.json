  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "1",
            "id": "46"
          },
          "text": [
            "when a flow matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>BB:CategoryDefinition: Successful Communication</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getFlowRules",
              "value": "SYSTEM-1472"
            }
          ]
        },
        {
          "_$": {
            "name": "AttackContext_Test",
            "uid": "2",
            "id": "25",
            "negate": "false"
          },
          "text": [
            "when the flow context is <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Local to Remote</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "l2r"
            }
          ]
        },
        {
          "_$": {
            "name": "DstPort_Test",
            "uid": "3",
            "id": "5",
            "negate": "true"
          },
          "text": [
            "when the destination port is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>25</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "25"
            }
          ]
        },
        {
          "_$": {
            "name": "XForceCategoryByIP_Test",
            "uid": "4",
            "id": "113"
          },
          "text": [
            "when <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>Destination IP</a> is categorized by X-Force as <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>Anonymization Services</a> with confidence value <a href='javascript:editParameter(\"4\", \"3\")' class='dynamic'>greater than</a> <a href='javascript:editParameter(\"4\", \"4\")' class='dynamic'>75</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getIPFlowDatabaseFields",
              "value": "destinationIP"
            },
            {
              "id": "2",
              "method": "getXForceIPCategories",
              "value": "2"
            },
            {
              "id": "3",
              "value": "gt"
            },
            {
              "id": "4",
              "value": "75"
            }
          ]
        }
      ]
    }
  ],
