  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "3",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(5001828) Process Create</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Parent Process Name IMATCHES '((psexesvc)|(wsmprovhost)|(wmiprvse))\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Parent%20Process%20Name%22%20IMATCHES%20'((psexesvc)%7C(wsmprovhost)%7C(wmiprvse))%5C.exe'|%5B%22%5C%22Parent%20Process%20Name%5C%22%20IMATCHES%20'((psexesvc)%7C(wsmprovhost)%7C(wmiprvse))%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "2",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>2</a> events are seen with the same <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>Process Name (custom)</a> and different <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Source IP</a> in <a href='javascript:editParameter(\"2\", \"5\")' class='dynamic'>15</a> <a href='javascript:editParameter(\"2\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "2"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "sourceIP"
            },
            {
              "id": "5",
              "value": "15"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        }
      ]
    }
  ],
