            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Parent Process Full Full Name&quot;) == 'svchost.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Parent%20Process%20Name%22)%20%3D%3D%20'svchost.exe'|%5B%22LOWER(%5C%22Parent%20Process%20Name%5C%22)%20%3D%3D%20'svchost.exe'%22%5D"
