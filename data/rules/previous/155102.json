          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001471) Success Audit: Network Share Object Checked for Access</a>"
          ],
          "parameter": [
            {
              "id": "1",
