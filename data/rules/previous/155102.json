              "value": "5001471"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "2",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Share Name (custom) is any of IPC$</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Share NameEQanyIPC$"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Filename (custom) is any of svcctl</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "FilenameEQanysvcctl"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "4",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>Accesses (custom) contains any of WriteData</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "AccessesCONanyWriteData"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
