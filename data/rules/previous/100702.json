          "_$": {
            "name": "EventCategory_Test",
            "uid": "2",
            "id": "21",
            "negate": "false"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Access.Access Denied, Access.ACL Deny, Access.Firewall Deny, Access.IPS Deny</a>"
