            "uid": "0",
            "id": "46"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"0\", \"2\")' class='dynamic'>BB:DeviceDefinition: Operating System</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "73022aff-8dd2-4bc0-b316-d86bd7e3ac7f"
            }
          ]
        },
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "4",
            "id": "46",
            "negate": "true"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>Malware as a Service Hash IOC in Events, Ransomware: Ryuk IOC in Events</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "8bbb2bff-5ba3-4a45-85d7-5a049f6dc471, c4851152-1fcd-4965-b3a4-3d3f06b2c9e7"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "1",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>Source Address, Destination Address</a> are contained in <a href='javascript:editParameter(\"1\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"1\", \"4\")' class='dynamic'>Known Turla IPs - IP</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "sourceaddress, destinationaddress"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "207"
            }
          ]
        }
      ]
