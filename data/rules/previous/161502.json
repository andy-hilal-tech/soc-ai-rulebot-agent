  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) IN ('isoburn.exe', 'poweriso.exe', 'imgburn.exe') AND LOWER(&quot;Parent Process Full Full Name&quot;) IN ('winrar.exe', '7zfm.exe', 'peazip.exe')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20IN%20('isoburn.exe'%2C%20'poweriso.exe'%2C%20'imgburn.exe')%20AND%20LOWER(%22Parent%20Process%20Name%22)%20IN%20('winrar.exe'%2C%20'7zfm.exe'%2C%20'peazip.exe')|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20IN%20('isoburn.exe'%2C%20'poweriso.exe'%2C%20'imgburn.exe')%22%2C%22AND%20LOWER(%5C%22Parent%20Process%20Name%5C%22)%20IN%20('winrar.exe'%2C%20'7zfm.exe'%2C%20'peazip.exe')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
