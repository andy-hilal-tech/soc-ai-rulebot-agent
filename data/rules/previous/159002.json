  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Parent Process Full Full Name&quot;) in ('wmiprvse.exe', 'services.exe', 'svchost.exe', 'wsmprovhost.exe', 'mmc.exe')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Parent%20Process%20Name%22)%20in%20('wmiprvse.exe'%2C%20'services.exe'%2C%20'svchost.exe'%2C%20'wsmprovhost.exe'%2C%20'mmc.exe')|%5B%22LOWER(%5C%22Parent%20Process%20Name%5C%22)%20in%20('wmiprvse.exe'%2C%20'services.exe'%2C%20'svchost.exe'%2C%20'wsmprovhost.exe'%2C%20'mmc.exe')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) LIKE 'powershell.exe' OR (LOWER(&quot;Process Full Full Name&quot;) LIKE 'cmd.exe' AND (LOWER(&quot;Command&quot;) LIKE '%powershell.exe%' OR LOWER(&quot;Command&quot;) LIKE '%pwsh.exe%')) OR LOWER(&quot;Process Full Full Name&quot;) LIKE 'pwsh.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20LIKE%20'powershell.exe'%20OR%20(LOWER(%22Process%20Name%22)%20LIKE%20'cmd.exe'%20AND%20(LOWER(%22Command%22)%20LIKE%20'%25powershell.exe%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25pwsh.exe%25'))%20OR%20LOWER(%22Process%20Name%22)%20LIKE%20'pwsh.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'powershell.exe'%20OR%20(LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'cmd.exe'%20AND%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25powershell.exe%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25pwsh.exe%25'))%20OR%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'pwsh.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
