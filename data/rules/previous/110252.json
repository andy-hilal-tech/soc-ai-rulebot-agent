  "rule_name": "Unusual Parent for a System Process",
  "object_type": "rule",
  "group": "Sysmon",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2017-08-13T23:27:26.370Z",
