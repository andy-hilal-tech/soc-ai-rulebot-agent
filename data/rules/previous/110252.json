  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "3",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(5001828) Process Create</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Process Name IMATCHES '((smss)|(wininit)|(taskhost)|(lsass)|(winlogon)|(explorer)|(lsm)|(svchost)|(services)|(csrss))\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Process%20Name%22%20IMATCHES%20'((smss)%7C(wininit)%7C(taskhost)%7C(lsass)%7C(winlogon)%7C(explorer)%7C(lsm)%7C(svchost)%7C(services)%7C(csrss))%5C.exe'|%5B%22%5C%22Process%20Name%5C%22%20IMATCHES%20'((smss)%7C(wininit)%7C(taskhost)%7C(lsass)%7C(winlogon)%7C(explorer)%7C(lsm)%7C(svchost)%7C(services)%7C(csrss))%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>REFERENCEMAPSETCONTAINS('ProcessMaptoProcessParentPath', LOWER(&quot;Process Name&quot;), LOWER(&quot;Parent Process Path&quot;)) != True</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "REFERENCEMAPSETCONTAINS('ProcessMaptoProcessParentPath'%2C%20LOWER(%22Process%20Name%22)%2C%20LOWER(%22Parent%20Process%20Path%22))%20!%3D%20True|%5B%22REFERENCEMAPSETCONTAINS('ProcessMaptoProcessParentPath'%2C%20LOWER(%5C%22Process%20Name%5C%22)%2C%20LOWER(%5C%22Parent%20Process%20Path%5C%22))%20!%3D%20True%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
