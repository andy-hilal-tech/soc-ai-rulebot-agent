  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success, Audit.Command Execution Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 19250"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>(((LOWER(&quot;Process Full Full Name&quot;) LIKE '%cacls.exe' OR LOWER(&quot;Process Full Full Name&quot;) LIKE '%icacls.exe' OR LOWER(&quot;Process Full Full Name&quot;) LIKE '%net.exe' OR LOWER(&quot;Process Full Full Name&quot;) LIKE '%net1.exe') AND (LOWER(&quot;Command&quot;) LIKE '%/grant everyone:f /t /c /q' OR LOWER(&quot;Command&quot;) LIKE '%/setowner%' OR LOWER(&quot;Command&quot;) LIKE '%/inheritance:r%')) OR (LOWER(&quot;Process Full Full Name&quot;) LIKE '%attrib.exe' AND LOWER(&quot;Command&quot;) LIKE '%-r%') OR LOWER(&quot;Process Full Full Name&quot;) LIKE '%takeown.exe')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(((LOWER(%22Process%20Name%22)%20LIKE%20'%25cacls.exe'%20OR%20LOWER(%22Process%20Name%22)%20LIKE%20'%25icacls.exe'%20OR%20LOWER(%22Process%20Name%22)%20LIKE%20'%25net.exe'%20OR%20LOWER(%22Process%20Name%22)%20LIKE%20'%25net1.exe')%20AND%20(LOWER(%22Command%22)%20LIKE%20'%25%2Fgrant%20everyone%3Af%20%2Ft%20%2Fc%20%2Fq'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25%2Fsetowner%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25%2Finheritance%3Ar%25'))%20OR%20(LOWER(%22Process%20Name%22)%20LIKE%20'%25attrib.exe'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25-r%25')%20OR%20LOWER(%22Process%20Name%22)%20LIKE%20'%25takeown.exe')|%5B%22(((LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25cacls.exe'%20OR%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25icacls.exe'%20OR%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25net.exe'%20OR%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25net1.exe')%20AND%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%2Fgrant%20everyone%3Af%20%2Ft%20%2Fc%20%2Fq'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%2Fsetowner%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%2Finheritance%3Ar%25'))%20OR%20(LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25attrib.exe'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25-r%25')%20OR%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25takeown.exe')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(LOWER(&quot;Command&quot;) LIKE '%ICACLS C:\\ProgramData\\dynatrace\\gateway\\config\\connectivity.history /reset' OR (LOWER(&quot;Command&quot;) LIKE '%ICACLS C:\\ProgramData\\dynatrace\\gateway\\config\\config.properties /grant :r %' AND LOWER(&quot;Command&quot;) LIKE '%S-1-5-19:F%') OR (LOWER(&quot;Command&quot;) LIKE '%\\AppData\\Local\\Programs\\Microsoft VS Code%' OR &quot;Parent Process File Path&quot; LIKE '%\\Microsoft VS Code\\Code.exe'))</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(%22Command%22)%20LIKE%20'%25ICACLS%20C%3A%5CProgramData%5Cdynatrace%5Cgateway%5Cconfig%5Cconnectivity.history%20%2Freset'%20OR%20(LOWER(%22Command%22)%20LIKE%20'%25ICACLS%20C%3A%5CProgramData%5Cdynatrace%5Cgateway%5Cconfig%5Cconfig.properties%20%2Fgrant%20%3Ar%20%25'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25S-1-5-19%3AF%25')%20OR%20(LOWER(%22Command%22)%20LIKE%20'%25%5CAppData%5CLocal%5CPrograms%5CMicrosoft%20VS%20Code%25'%20OR%20%22Parent%20Process%20Path%22%20LIKE%20'%25%5CMicrosoft%20VS%20Code%5CCode.exe'))|%5B%22(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25ICACLS%20C%3A%5C%5CProgramData%5C%5Cdynatrace%5C%5Cgateway%5C%5Cconfig%5C%5Cconnectivity.history%20%2Freset'%20OR%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25ICACLS%20C%3A%5C%5CProgramData%5C%5Cdynatrace%5C%5Cgateway%5C%5Cconfig%5C%5Cconfig.properties%20%2Fgrant%20%3Ar%20%25'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25S-1-5-19%3AF%25')%20OR%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5CAppData%5C%5CLocal%5C%5CPrograms%5C%5CMicrosoft%20VS%20Code%25'%20OR%20%5C%22Parent%20Process%20Path%5C%22%20LIKE%20'%25%5C%5CMicrosoft%20VS%20Code%5C%5CCode.exe'))%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
