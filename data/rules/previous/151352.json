  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.File Created, System.Successful File Modification</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8028, 8014"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;File File File Path&quot;) LIKE '%\\microsoft\\outlook\\%' AND LOWER(&quot;Filename&quot;) == 'vbaproject.otm'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22File%20Path%22)%20LIKE%20'%25%5Cmicrosoft%5Coutlook%5C%25'%20AND%20LOWER(%22Filename%22)%20%3D%3D%20'vbaproject.otm'|%5B%22LOWER(%5C%22File%20Path%5C%22)%20LIKE%20'%25%5C%5Cmicrosoft%5C%5Coutlook%5C%5C%25'%22%2C%22AND%20LOWER(%5C%22Filename%5C%22)%20%3D%3D%20'vbaproject.otm'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
