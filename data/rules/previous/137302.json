  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "4",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>Process Path (custom) is not N/A, Process Name (custom) is not N/A</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process PathNENA$_NULL_$Process NameNENA$_NULL_$"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "3",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>Process Name (custom)</a> are contained in <a href='javascript:editParameter(\"3\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"4\")' class='dynamic'>Sensitive Process Names - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "214"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceDataTest",
            "uid": "2",
            "id": "110",
            "negate": "true"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>Process Name (custom)</a> is the key and <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Process Path (custom)</a> is the value in <a href='javascript:editParameter(\"2\", \"5\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"6\")' class='dynamic'>Default Process Name and Process Directories - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "Process Path"
            },
            {
              "id": "5",
              "value": "any"
            },
            {
              "id": "6",
              "method": "getReferenceDataMapsOfSets",
              "value": "215"
            }
          ]
        }
      ]
    }
  ],
