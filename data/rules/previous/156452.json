          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "2",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Process Name (custom) is any of msedge.exe</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process NameEQanymsedge.exe"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Parent Process Name (custom) is any of [cmd.exe or powershell.exe or pwsh.exe or powershell_ise.exe]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Parent Process NameEQanycmd.exe�powershell.exe�pwsh.exe�powershell_ise.exe"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>(LOWER(&quot;Command&quot;) LIKE '%http://%' OR LOWER(&quot;Command&quot;) LIKE '%https://%' OR LOWER(&quot;Command&quot;) LIKE '%ftp://%' OR LOWER(&quot;Command&quot;) LIKE '%www.%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(%22Command%22)%20LIKE%20'%25http%3A%2F%2F%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25https%3A%2F%2F%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25ftp%3A%2F%2F%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25www.%25')|%5B%22(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25http%3A%2F%2F%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25https%3A%2F%2F%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25ftp%3A%2F%2F%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25www.%25')%22%5D"
