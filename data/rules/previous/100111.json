          ]
        },
        {
          "_$": {
            "name": "ThresholdFunction_Test",
            "uid": "4",
            "id": "80"
          },
          "text": [
            "when any of these <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>BB:CategoryDefinition: Recon Events, BB:CategoryDefinition: Suspicious Events</a> with the same <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>source IP</a> more than <a href='javascript:editParameter(\"4\", \"3\")' class='dynamic'>5</a> times, across <a href='javascript:editParameter(\"4\", \"4\")' class='dynamic'>more than</a> <a href='javascript:editParameter(\"4\", \"5\")' class='dynamic'>59</a> <a href='javascript:editParameter(\"4\", \"6\")' class='dynamic'>destination IP</a> within <a href='javascript:editParameter(\"4\", \"7\")' class='dynamic'>10</a> <a href='javascript:editParameter(\"4\", \"8\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": "SYSTEM-1202, SYSTEM-1179"
            },
            {
              "id": "2",
              "value": "SourceIP"
