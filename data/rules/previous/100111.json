      "test": [
        {
          "_$": {
            "name": "IPProtocol_Test",
            "uid": "3",
            "id": "2"
          },
          "text": [
            "when the IP protocol is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>other, Uncommon</a>"
