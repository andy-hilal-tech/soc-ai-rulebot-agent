  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001829) ProcessAccess</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001829"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "4",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>Process Name (custom) is any of winword.exe</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process NameEQanywinword.exe"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Call Trace&quot;) LIKE '%:\\windows\\microsoft.net\\framework64\\v2%' AND LOWER(&quot;Call Trace&quot;) LIKE '%unknown%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Call%20Trace%22)%20LIKE%20'%25%3A%5Cwindows%5Cmicrosoft.net%5Cframework64%5Cv2%25'%20AND%20LOWER(%22Call%20Trace%22)%20LIKE%20'%25unknown%25'|%5B%22LOWER(%5C%22Call%20Trace%5C%22)%20LIKE%20'%25%3A%5C%5Cwindows%5C%5Cmicrosoft.net%5C%5Cframework64%5C%5Cv2%25'%22,%22AND%20LOWER(%5C%22Call%20Trace%5C%22)%20LIKE%20'%25unknown%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
