  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Audit.Object Access Success, System.Process Creation Success, Audit.Command Execution Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "19081, 8110, 19250"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "2",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Process Name (custom) is any of [reg.exe or regedit.exe or regedit32.exe]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process NameEQanyreg.exe�regedit.exe�regedit32.exe"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Command&quot;) MATCHES '.*?reg(\\.exe\\&quot;)?\\s+(add|query|save).*(uselogoncredential|password|sam|system|security).*' OR LOWER(&quot;Registry Key&quot;) MATCHES '\\\\system\\\\(controlset001|controlset002|currentcontrolset).*wdigest'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20MATCHES%20'.*%3Freg(%5C.exe%5C%22)%3F%5Cs%2B(add%7Cquery%7Csave).*(uselogoncredential%7Cpassword%7Csam%7Csystem%7Csecurity).*'%20OR%20LOWER(%22Registry%20Key%22)%20MATCHES%20'%5C%5Csystem%5C%5C(controlset001%7Ccontrolset002%7Ccurrentcontrolset).*wdigest'|%5B%22LOWER(%5C%22Command%5C%22)%20MATCHES%20'.*%3Freg(%5C%5C.exe%5C%5C%5C%22)%3F%5C%5Cs%2B(add%7Cquery%7Csave).*(uselogoncredential%7Cpassword%7Csam%7Csystem%7Csecurity).*'%20OR%20LOWER(%5C%22Registry%20Key%5C%22)%20MATCHES%20'%5C%5C%5C%5Csystem%5C%5C%5C%5C(controlset001%7Ccontrolset002%7Ccurrentcontrolset).*wdigest'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
