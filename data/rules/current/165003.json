  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "4",
            "id": "46"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>BB:DeviceDefinition: Operating System</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "73022aff-8dd2-4bc0-b316-d86bd7e3ac7f"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "0",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>System.Process Creation Success, Audit.Command Execution Attempt</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 19252"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>&quot;Command&quot; IS NOT NULL OR &quot;Command Arguments&quot; IS NOT NULL</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Command%22%20IS%20NOT%20NULL%20OR%20%22Command%20Arguments%22%20IS%20NOT%20NULL|%5B%22%5C%22Command%5C%22%20IS%20NOT%20NULL%20OR%20%5C%22Command%20Arguments%5C%22%20IS%20NOT%20NULL%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "PropertyRegex",
            "uid": "3",
            "id": "225"
          },
          "text": [
            "when any of <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Command (custom), Command Arguments (custom)</a> match <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>(?i).*\\b(miner|pool|coinhive|cryptonight|ethereum|xrp|stellar|monero|bitcoin)\\b.*</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventDatabaseFields",
              "value": "Command, Command Arguments"
            },
            {
              "id": "2",
              "value": "(?i).*\\b(miner|pool|coinhive|cryptonight|ethereum|xrp|stellar|monero|bitcoin)\\b.*"
            }
          ]
        }
      ]
    }
  ],
