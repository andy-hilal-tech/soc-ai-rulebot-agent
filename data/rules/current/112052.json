  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001828) Process Create, (5000862) Success Audit: A new process has been created</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828,                                                                                                                                                                                                                                                                                                                  5000862"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Process Name IMATCHES 'svchost.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Process%20Name%22%20IMATCHES%20'svchost.exe'|%5B%22%5C%22Process%20Name%5C%22%20IMATCHES%20'svchost.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "4",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>Command (custom) is not N/A</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "CommandNENA$_NULL_$"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>&quot;Command&quot; NOT IMATCHES 'C\\:\\\\Windows\\\\((System32)|(SysWow64))\\\\svchost\\.exe\\s\\-k.*'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Command%22%20NOT%20IMATCHES%20'C%5C%3A%5C%5CWindows%5C%5C((System32)%7C(SysWow64))%5C%5Csvchost%5C.exe%5Cs%5C-k.*'|%5B%22%5C%22Command%5C%22%20NOT%20IMATCHES%20'C%5C%5C%3A%5C%5C%5C%5CWindows%5C%5C%5C%5C((System32)%7C(SysWow64))%5C%5C%5C%5Csvchost%5C%5C.exe%5C%5Cs%5C%5C-k.*'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
