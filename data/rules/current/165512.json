  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Cisco Aironet</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "182"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(47500074) Interface power granted, (47500073) Interface Power detected</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "47500074, 47500073"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "2",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>7</a> events are seen with the same <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>Log Source Type</a> and different <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Interface_CAN (custom)</a> in <a href='javascript:editParameter(\"2\", \"5\")' class='dynamic'>30</a> <a href='javascript:editParameter(\"2\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "7"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "deviceType"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "Interface_CAN"
            },
            {
              "id": "5",
              "value": "30"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        }
      ]
    }
