  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2023-03-16T13:33:21.271Z",
  "modified": "2024-07-21T12:38:48.920Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001844) Image loaded</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001844"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "5",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>LOWER(&quot;Description&quot;) LIKE '%python core%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Description%22)%20LIKE%20'%25python%20core%25'|%5B%22LOWER(%5C%22Description%5C%22)%20LIKE%20'%25python%20core%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Process Name (custom) contains any of python</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process NameCONanypython"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Process File File Path&quot;) LIKE 'c:\\program files\\%' or LOWER(&quot;Process File File Path&quot;) LIKE 'c:\\program files (x86)\\%' or LOWER(&quot;Process File File Path&quot;) LIKE 'c:\\programdata\\anaconda3\\%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Path%22)%20LIKE%20'c%3A%5Cprogram%20files%5C%25'%20or%20LOWER(%22Process%20Path%22)%20LIKE%20'c%3A%5Cprogram%20files%20(x86)%5C%25'%20or%20LOWER(%22Process%20Path%22)%20LIKE%20'c%3A%5Cprogramdata%5Canaconda3%5C%25'|%5B%22LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'c%3A%5C%5Cprogram%20files%5C%5C%25'%20or%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'c%3A%5C%5Cprogram%20files%20(x86)%5C%5C%25'%20or%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'c%3A%5C%5Cprogramdata%5C%5Canaconda3%5C%5C%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
