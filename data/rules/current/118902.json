            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Apache HTTP Server, Amazon AWS WAF, Microsoft IIS, NGINX HTTP Server, Amazon AWS Elastic Kubernetes Service, F5 Networks BIG-IP ASM</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "10, 501, 13, 439, 502, 213"
            }
          ]
        },
        {
          "_$": {
            "name": "PropertyRegex",
            "uid": "1",
            "id": "225"
          },
          "text": [
            "when any of <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>URL Referrer (custom), URL (custom), URL Host (custom), Request URI (custom)</a> match <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>(?i)(\\$|%24)(\\{|%7B)[^\\}]*?j.*?n.*?d.*?i</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventDatabaseFields",
              "value": "URL Referrer, URL, URL Host, Request URI"
            },
            {
              "id": "2",
              "value": "(?i)(\\$|%24)(\\{|%7B)[^\\}]*?j.*?n.*?d.*?i"
            }
          ]
        }
      ]
    }
  ],
