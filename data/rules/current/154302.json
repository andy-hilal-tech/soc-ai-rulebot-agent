            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "242"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>((LOWER(&quot;File Directory&quot;) LIKE 'C:\\Windows\\System32\\%' OR LOWER(&quot;File Directory&quot;) LIKE 'C:\\Windows\\SysWOW64\\%' OR LOWER(&quot;File Directory&quot;) LIKE 'C:\\Windows\\WinSxS\\%' OR LOWER(&quot;File Directory&quot;) LIKE 'C:\\Windows\\SoftwareDistribution\\%' OR LOWER(&quot;File Directory&quot;) LIKE 'C:\\Windows\\SystemTemp\\%') OR (LOWER(&quot;File Directory&quot;) = 'C:\\Application Files\\Common Files\\microsoft shared\\ClickToRun\\%' AND LOWER(&quot;Process File File Path&quot;)='C:\\Application Files\\Common Files\\microsoft shared\\ClickToRun\\OfficeClickToRun.exe') OR LOWER(&quot;File Directory&quot;) LIKE 'C:\\Packages\\Plugins\\Microsoft.GuestConfiguration.ConfigurationforWindows\\%' OR ((LOWER(&quot;Process File File Path&quot;) LIKE 'C:\\Application Files\\WindowsApps\\DellInc.DellSupportAssistforPCs%' OR LOWER(&quot;Process File File Path&quot;) LIKE 'C:\\Windows\\System32\\backgroundTaskHost.exe%') AND LOWER(&quot;File Directory&quot;) LIKE 'C:\\Application Files\\WindowsApps\\DellInc.DellSupportAssistforPCs%') OR (LOWER(&quot;Process File File Path&quot;) ='C:\\Windows\\System32\\%' AND LOWER(&quot;File Directory&quot;) LIKE '%\\ssshim.dll') OR LOWER(&quot;Process File File Path&quot;) LIKE 'C:\\$WINDOWS.~BT\\%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "((LOWER(%22File%20Directory%22)%20LIKE%20'C%3A%5CWindows%5CSystem32%5C%25'%20OR%20LOWER(%22File%20Directory%22)%20LIKE%20'C%3A%5CWindows%5CSysWOW64%5C%25'%20OR%20LOWER(%22File%20Directory%22)%20LIKE%20'C%3A%5CWindows%5CWinSxS%5C%25'%20OR%20LOWER(%22File%20Directory%22)%20LIKE%20'C%3A%5CWindows%5CSoftwareDistribution%5C%25'%20OR%20LOWER(%22File%20Directory%22)%20LIKE%20'C%3A%5CWindows%5CSystemTemp%5C%25')%20OR%20(LOWER(%22File%20Directory%22)%20%3D%20'C%3A%5CProgram%20Files%5CCommon%20Files%5Cmicrosoft%20shared%5CClickToRun%5C%25'%20AND%20LOWER(%22Process%20Path%22)%3D'C%3A%5CProgram%20Files%5CCommon%20Files%5Cmicrosoft%20shared%5CClickToRun%5COfficeClickToRun.exe')%20OR%20LOWER(%22File%20Directory%22)%20LIKE%20'C%3A%5CPackages%5CPlugins%5CMicrosoft.GuestConfiguration.ConfigurationforWindows%5C%25'%20OR%20((LOWER(%22Process%20Path%22)%20LIKE%20'C%3A%5CProgram%20Files%5CWindowsApps%5CDellInc.DellSupportAssistforPCs%25'%20OR%20LOWER(%22Process%20Path%22)%20LIKE%20'C%3A%5CWindows%5CSystem32%5CbackgroundTaskHost.exe%25')%20AND%20LOWER(%22File%20Directory%22)%20LIKE%20'C%3A%5CProgram%20Files%5CWindowsApps%5CDellInc.DellSupportAssistforPCs%25')%20OR%20(LOWER(%22Process%20Path%22)%20%3D'C%3A%5CWindows%5CSystem32%5C%25'%20AND%20LOWER(%22File%20Directory%22)%20LIKE%20'%25%5Cssshim.dll')%20OR%20LOWER(%22Process%20Path%22)%20LIKE%20'C%3A%5C%24WINDOWS.%7EBT%5C%25')|%5B%22((LOWER(%5C%22File%20Directory%5C%22)%20LIKE%20'C%3A%5C%5CWindows%5C%5CSystem32%5C%5C%25'%20OR%20LOWER(%5C%22File%20Directory%5C%22)%20LIKE%20'C%3A%5C%5CWindows%5C%5CSysWOW64%5C%5C%25'%20OR%20LOWER(%5C%22File%20Directory%5C%22)%20LIKE%20'C%3A%5C%5CWindows%5C%5CWinSxS%5C%5C%25'%20OR%20LOWER(%5C%22File%20Directory%5C%22)%20LIKE%20'C%3A%5C%5CWindows%5C%5CSoftwareDistribution%5C%5C%25'%20OR%20LOWER(%5C%22File%20Directory%5C%22)%20LIKE%20'C%3A%5C%5CWindows%5C%5CSystemTemp%5C%5C%25')%20OR%20(LOWER(%5C%22File%20Directory%5C%22)%20%3D%20'C%3A%5C%5CProgram%20Files%5C%5CCommon%20Files%5C%5Cmicrosoft%20shared%5C%5CClickToRun%5C%5C%25'%20AND%20LOWER(%5C%22Process%20Path%5C%22)%3D'C%3A%5C%5CProgram%20Files%5C%5CCommon%20Files%5C%5Cmicrosoft%20shared%5C%5CClickToRun%5C%5COfficeClickToRun.exe')%20OR%20LOWER(%5C%22File%20Directory%5C%22)%20LIKE%20'C%3A%5C%5CPackages%5C%5CPlugins%5C%5CMicrosoft.GuestConfiguration.ConfigurationforWindows%5C%5C%25'%20OR%20((LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'C%3A%5C%5CProgram%20Files%5C%5CWindowsApps%5C%5CDellInc.DellSupportAssistforPCs%25'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'C%3A%5C%5CWindows%5C%5CSystem32%5C%5CbackgroundTaskHost.exe%25')%20AND%20LOWER(%5C%22File%20Directory%5C%22)%20LIKE%20'C%3A%5C%5CProgram%20Files%5C%5CWindowsApps%5C%5CDellInc.DellSupportAssistforPCs%25')%20OR%20(LOWER(%5C%22Process%20Path%5C%22)%20%3D'C%3A%5C%5CWindows%5C%5CSystem32%5C%5C%25'%20AND%20LOWER(%5C%22File%20Directory%5C%22)%20LIKE%20'%25%5C%5Cssshim.dll')%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'C%3A%5C%5C%24WINDOWS.%7EBT%5C%5C%25')%22%5D"
