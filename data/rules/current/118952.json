  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "PropertyMatch_Test",
            "uid": "1",
            "id": "321"
          },
          "text": [
            "when <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Source IP</a> <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>not equals</a> <a href='javascript:editParameter(\"1\", \"3\")' class='dynamic'>Destination IP</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventDatabaseFields",
              "value": "sourceIP"
            },
            {
              "id": "2",
              "value": "notEquals"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "destinationIP"
            }
          ]
        },
        {
          "_$": {
            "name": "DoubleSequenceFunction_Test",
            "uid": "0",
            "id": "94"
          },
          "text": [
            "when a subset of at least <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>1</a> of these <a href='javascript:editParameter(\"0\", \"2\")' class='dynamic'>BB:CategoryDefinition: Exploits Backdoors and Trojans</a>, <a href='javascript:editParameter(\"0\", \"3\")' class='dynamic'>in</a> order, with the same <a href='javascript:editParameter(\"0\", \"4\")' class='dynamic'>source IP</a> followed by a subset of at least <a href='javascript:editParameter(\"0\", \"5\")' class='dynamic'>1</a> of these <a href='javascript:editParameter(\"0\", \"6\")' class='dynamic'>BB:CategoryDefinition: Post Exploit Account Activity</a> <a href='javascript:editParameter(\"0\", \"7\")' class='dynamic'>in</a> order <a href='javascript:editParameter(\"0\", \"11\")' class='dynamic'>from</a> the same <a href='javascript:editParameter(\"0\", \"8\")' class='dynamic'>destination IP</a> from the previous sequence, within <a href='javascript:editParameter(\"0\", \"9\")' class='dynamic'>15</a> <a href='javascript:editParameter(\"0\", \"10\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "1"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "SYSTEM-1204"
            },
            {
              "id": "3",
              "value": "In"
            },
