  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "0",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Malware</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "6000"
            }
          ]
        },
        {
          "_$": {
            "name": "AttackContext_Test",
            "uid": "1",
            "id": "25"
          },
          "text": [
            "when the event context is <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Local to Local, Local to Remote</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "l2l, l2r"
            }
          ]
        },
        {
          "_$": {
            "name": "PropertyMatch_Test",
            "uid": "2",
            "id": "321"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Source IP</a> <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>not equals</a> <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>Destination IP</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventDatabaseFields",
              "value": "sourceIP"
            },
            {
              "id": "2",
              "value": "notEquals"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "destinationIP"
            }
          ]
        }
      ]
    }
  ],
