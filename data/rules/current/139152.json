  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "6",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"6\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Successful Registry Modification</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8012"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "2",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Rule Name (custom) contains any of T1138</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Rule NameCONanyT1138"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "5",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>Registry Value Data (custom) is not N/A</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Registry Value DataNENA$_NULL_$"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Registry Value Data&quot;) MATCHES '.*?\\\\(apppatch\\\\(?:apppatch64\\\\)?custom(?:sdb)?).*'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Registry%20Value%20Data%22)%20MATCHES%20'.*%3F%5C%5C(apppatch%5C%5C(%3F%3Aapppatch64%5C%5C)%3Fcustom(%3F%3Asdb)%3F).*'|%5B%22LOWER(%5C%22Registry%20Value%20Data%5C%22)%20MATCHES%20'.*%3F%5C%5C%5C%5C(apppatch%5C%5C%5C%5C(%3F%3Aapppatch64%5C%5C%5C%5C)%3Fcustom(%3F%3Asdb)%3F).*'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "4",
            "id": "107",
            "negate": "true"
          },
          "text": [
            "when <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>Registry Value Data (custom)</a> are contained in <a href='javascript:editParameter(\"4\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"4\", \"4\")' class='dynamic'>Shims Allowlist - AlphaNumeric</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Registry Value Data"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "217"
            }
          ]
        }
      ]
    }
  ],
