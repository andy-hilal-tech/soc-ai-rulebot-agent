  "rule_doc_id": "160902",
  "rule_id": "160902",
  "uuid": "d7aa4426-0a14-4091-9c93-7e602c115f3c",
  "rule_name": "Disabled CrashDump via Registry",
  "object_type": "rule",
  "group": "Turla, Endpoint",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2023-02-23T14:47:57.754Z",
  "modified": "2024-07-21T12:38:42.321Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "4",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>(5001832) RegistryEvent (Value Set)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001832"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>LOWER(&quot;Registry Key&quot;) LIKE '%system\\currentcontrolset\\control\\crashcontrol%' AND LOWER(&quot;Registry Value Data&quot;) LIKE '%dword (0x00000000)%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Registry%20Key%22)%20LIKE%20'%25system%5Ccurrentcontrolset%5Ccontrol%5Ccrashcontrol%25'%20AND%20LOWER(%22Registry%20Value%20Data%22)%20LIKE%20'%25dword%20(0x00000000)%25'|%5B%22LOWER(%5C%22Registry%20Key%5C%22)%20LIKE%20'%25system%5C%5Ccurrentcontrolset%5C%5Ccontrol%5C%5Ccrashcontrol%25'%22,%22AND%20LOWER(%5C%22Registry%20Value%20Data%5C%22)%20LIKE%20'%25dword%20(0x00000000)%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "_$": {
        "flowAnalysisInterval": "0",
        "includeAttackerEventsInterval": "0",
        "forceOffenseCreation": "true",
        "offenseMapping": "0"
      }
    }
  ],
  "dependencies": [],
  "limiter": [
    {
      "_$": {
        "hostType": "ATTACKER",
        "intervalType": "h",
        "intervalCount": "1",
        "responseCount": "1"
      }
    }
  ],
