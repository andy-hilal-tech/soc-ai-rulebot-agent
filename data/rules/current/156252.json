  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success, Exploit.Command Execution</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 5034"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>((LOWER(&quot;Command&quot;) LIKE '%\\\\\\\\%' AND LOWER(&quot;Command&quot;) LIKE '%$%') OR LOWER(&quot;Command&quot;) LIKE '%\\sysvol\\%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "((LOWER(%22Command%22)%20LIKE%20'%25%5C%5C%5C%5C%25'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25%24%25')%20OR%20LOWER(%22Command%22)%20LIKE%20'%25%5Csysvol%5C%25')|%5B%22((LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5C%5C%5C%5C%5C%5C%5C%25'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%24%25')%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5Csysvol%5C%5C%25')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>((((LOWER(&quot;Process Full Full Name&quot;) LIKE '%\\robocopy.exe' or LOWER(&quot;Process Full Full Name&quot;) LIKE '%\\xcopy.exe') or (LOWER(&quot;Filename&quot;) LIKE '%robocopy.exe%' or LOWER(&quot;Filename&quot;) LIKE '%xcopy.exe%')) or ((LOWER(&quot;Process Full Full Name&quot;) LIKE '%\\cmd.exe' or LOWER(&quot;Filename&quot;) LIKE '%cmd.exe%') and LOWER(&quot;Command&quot;) LIKE '%copy%')) or (((LOWER(&quot;Process Full Full Name&quot;) LIKE '%\\powershell.exe%' or LOWER(&quot;Process Full Full Name&quot;) LIKE '%\\pwsh.exe%') or (LOWER(&quot;Filename&quot;) LIKE '%powershell.exe%' or LOWER(&quot;Filename&quot;) LIKE '%pwsh.dll%')) and (LOWER(&quot;Command&quot;) LIKE '%copy-item%' or LOWER(&quot;Command&quot;) LIKE '%copy %' or LOWER(&quot;Command&quot;) LIKE '%cpi %' or LOWER(&quot;Command&quot;) LIKE '% cp %' or LOWER(&quot;Command&quot;) LIKE '%move %' or LOWER(&quot;Command&quot;) LIKE '%move-item%' or LOWER(&quot;Command&quot;) LIKE '% mi %' or LOWER(&quot;Command&quot;) LIKE '% mv %')))</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "((((LOWER(%22Process%20Name%22)%20LIKE%20'%25%5Crobocopy.exe'%20or%20LOWER(%22Process%20Name%22)%20LIKE%20'%25%5Cxcopy.exe')%20or%20(LOWER(%22Filename%22)%20LIKE%20'%25robocopy.exe%25'%20or%20LOWER(%22Filename%22)%20LIKE%20'%25xcopy.exe%25'))%20or%20((LOWER(%22Process%20Name%22)%20LIKE%20'%25%5Ccmd.exe'%20or%20LOWER(%22Filename%22)%20LIKE%20'%25cmd.exe%25')%20and%20LOWER(%22Command%22)%20LIKE%20'%25copy%25'))%20or%20(((LOWER(%22Process%20Name%22)%20LIKE%20'%25%5Cpowershell.exe%25'%20or%20LOWER(%22Process%20Name%22)%20LIKE%20'%25%5Cpwsh.exe%25')%20or%20(LOWER(%22Filename%22)%20LIKE%20'%25powershell.exe%25'%20or%20LOWER(%22Filename%22)%20LIKE%20'%25pwsh.dll%25'))%20and%20(LOWER(%22Command%22)%20LIKE%20'%25copy-item%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25copy%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25cpi%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25%20cp%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25move%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25move-item%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25%20mi%20%25'%20or%20LOWER(%22Command%22)%20LIKE%20'%25%20mv%20%25')))|%5B%22((((LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25%5C%5Crobocopy.exe'%20or%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25%5C%5Cxcopy.exe')%20or%20(LOWER(%5C%22Filename%5C%22)%20LIKE%20'%25robocopy.exe%25'%20or%20LOWER(%5C%22Filename%5C%22)%20LIKE%20'%25xcopy.exe%25'))%20or%20((LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25%5C%5Ccmd.exe'%20or%20LOWER(%5C%22Filename%5C%22)%20LIKE%20'%25cmd.exe%25')%20and%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25copy%25'))%20or%20(((LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25%5C%5Cpowershell.exe%25'%20or%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25%5C%5Cpwsh.exe%25')%20or%20(LOWER(%5C%22Filename%5C%22)%20LIKE%20'%25powershell.exe%25'%20or%20LOWER(%5C%22Filename%5C%22)%20LIKE%20'%25pwsh.dll%25'))%20and%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25copy-item%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25copy%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25cpi%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20cp%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25move%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25move-item%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20mi%20%25'%20or%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20mv%20%25')))%22%5D"
            },
            {
