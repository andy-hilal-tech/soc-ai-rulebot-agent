  "rule_name": "Excessive System Tools Usage from a Single Host",
  "object_type": "rule",
  "group": "Sysmon",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event, Add to a Reference Set",
  "created": "2017-08-18T02:14:57.650Z",
  "modified": "2024-02-19T16:49:24.052Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001828) Process Create, (5000862) Success Audit: A new process has been created</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828,                                                                                                                                                                                                                                                                                             5000862"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "2",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>Process Name (custom)</a> are contained in <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Systools - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "75"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "3",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>7</a> events are seen with the same <a href='javascript:editParameter(\"3\", \"3\")' class='dynamic'>Source IP</a> and different <a href='javascript:editParameter(\"3\", \"4\")' class='dynamic'>Process Name (custom)</a> in <a href='javascript:editParameter(\"3\", \"5\")' class='dynamic'>1</a> <a href='javascript:editParameter(\"3\", \"6\")' class='dynamic'>hour(s)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "7"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "sourceIP"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "5",
              "value": "1"
            },
            {
              "id": "6",
              "value": "h"
            }
          ]
        }
      ]
    }
  ],
