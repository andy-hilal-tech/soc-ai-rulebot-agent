          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001828) Process Create, (5000862) Success Audit: A new process has been created</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828,                                                                                                                                                                                                                                                                                       5000862"
            }
          ]
        },
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "2",
            "id": "46"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>BB: Detected a Powershell Process</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "7f927b1c-d30b-48d2-ac06-c80b56ea033c"
