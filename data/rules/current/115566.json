          ]
        },
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "3",
            "id": "46",
            "negate": "true"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>Powershell Has Been Launched in a Compromised Host</a>"
          ],
          "parameter": [
            {
              "id": "1",
