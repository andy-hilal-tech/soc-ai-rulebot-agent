  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "0",
            "id": "46"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"0\", \"2\")' class='dynamic'>BB:CategoryDefinition: Authentication Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "SYSTEM-1220"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "1",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>Destination IP</a> are contained in <a href='javascript:editParameter(\"1\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"1\", \"4\")' class='dynamic'>Critical Assets - IP</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "destinationIP"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "21"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceDataTest",
            "uid": "2",
            "id": "110",
            "negate": "true"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>Username</a> is the key and <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Destination IP</a> is the value in <a href='javascript:editParameter(\"2\", \"5\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"6\")' class='dynamic'>User-System Authentication or Usage - IP</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "userName"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "destinationIP"
            },
            {
              "id": "5",
              "value": "any"
            },
            {
              "id": "6",
              "method": "getReferenceDataMapsOfSets",
              "value": "20"
            }
          ]
        },
        {
          "_$": {
            "name": "Regex_Test",
            "uid": "3",
            "id": "100"
          },
          "text": [
            "when the <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>event username</a> matches the following <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>[^\\w\\d]*</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "EventUserName"
            },
            {
              "id": "2",
              "value": "[^\\w\\d]*"
            }
          ]
        }
      ]
    }
  ],
