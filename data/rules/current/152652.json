  "rule_name": "DNS HybridConnectionManager Service Bus",
  "object_type": "rule",
  "group": "Turla, Endpoint",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2023-02-23T13:55:31.032Z",
  "modified": "2024-07-21T12:38:51.958Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Application.DNS In Progress</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "18081"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;URL Host&quot;) LIKE '%servicebus.windows.net%' AND LOWER(&quot;Process Full Full Name&quot;) LIKE '%hybridconnectionmanager%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22URL%20Host%22)%20LIKE%20'%25servicebus.windows.net%25'%20AND%20LOWER(%22Process%20Name%22)%20LIKE%20'%25hybridconnectionmanager%25'|%5B%22LOWER(%5C%22URL%20Host%5C%22)%20LIKE%20'%25servicebus.windows.net%25'%22%2C%22AND%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'%25hybridconnectionmanager%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "_$": {
        "flowAnalysisInterval": "0",
        "includeAttackerEventsInterval": "0",
        "forceOffenseCreation": "true",
        "offenseMapping": "0"
      }
    }
  ],
