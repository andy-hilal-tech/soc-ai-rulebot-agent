  "rule_name": "Unusual Parent for a Process",
  "object_type": "rule",
  "group": "Sysmon",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "OVERRIDE",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2024-02-19T17:03:23.008Z",
  "modified": "2024-04-24T11:44:04.717Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "3",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(5001828) Process Create</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "4",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>Process Name (custom)</a> are contained in <a href='javascript:editParameter(\"4\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"4\", \"4\")' class='dynamic'>(Shared) ProcesstoParentProcessPathRefMapKeys - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "77"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>REFERENCEMAPSETCONTAINS('ProcessMaptoProcessParentPath', LOWER(&quot;Process Name&quot;), LOWER(&quot;Parent Process Path&quot;))</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "REFERENCEMAPSETCONTAINS('ProcessMaptoProcessParentPath',%20LOWER(%22Process%20Name%22),%20LOWER(%22Parent%20Process%20Path%22))|%5B%22REFERENCEMAPSETCONTAINS('ProcessMaptoProcessParentPath',%20LOWER(%5C%22Process%20Name%5C%22),%20LOWER(%5C%22Parent%20Process%20Path%5C%22))%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "2",
            "id": "107",
            "negate": "true"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>MD5 Hash (custom), Process Name (custom), Parent Process Name (custom), Process Path (custom)</a> are contained in <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>(Shared) Unusual parent MD5 - AlphaNumeric, (Shared) P.Name - AlphaNumeric, (Shared) PP.name - AlphaNumeric, (Shared) P.path - AlphaNumeric</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "MD5 Hash, Process Name, Parent Process Name, Process Path"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "157, 155, 156, 158"
            }
          ]
        }
      ]
    }
  ],
