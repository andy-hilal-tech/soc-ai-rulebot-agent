            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Registry Key&quot;) LIKE '%\\inprocserver32\\%' OR LOWER(&quot;Registry Key&quot;) LIKE '%\\localserver32\\%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Registry%20Key%22)%20LIKE%20'%25%5Cinprocserver32%5C%25'%20OR%20LOWER(%22Registry%20Key%22)%20LIKE%20'%25%5Clocalserver32%5C%25'|%5B%22LOWER(%5C%22Registry%20Key%5C%22)%20LIKE%20'%25%5C%5Cinprocserver32%5C%5C%25'%20OR%20LOWER(%5C%22Registry%20Key%5C%22)%20LIKE%20'%25%5C%5Clocalserver32%5C%5C%25'%22%5D"
