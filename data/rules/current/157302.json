            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Registry Key&quot;) LIKE '%\\clsid\\%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Registry%20Key%22)%20LIKE%20'%25%5Cclsid%5C%25'|%5B%22LOWER(%5C%22Registry%20Key%5C%22)%20LIKE%20'%25%5C%5Cclsid%5C%5C%25'%22%5D"
