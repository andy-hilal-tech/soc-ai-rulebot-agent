            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Registry Value Data&quot;) LIKE '%\\users\\public\\%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%\\desktop\\%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%\\appdata\\%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%\\downloads\\%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%\\windows\\temp\\%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%\\start menu\\programs\\startup\\%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%\\system32\\spool\\drivers\\color\\%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%%temp%%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%%tmp%%' or LOWER(&quot;Registry Value Data&quot;) LIKE '%%appdata%%'</a> AQL filter query"
