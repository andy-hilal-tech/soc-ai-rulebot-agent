            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "2",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Authentication.User Login Failure</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "3116"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "0",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Logon Type (custom) is any of 3</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Logon TypeEQany3"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "4",
            "id": "304"
          },
          "text": [
            "when <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>BB:CategoryDefinition: Authentication Failures</a> match at least <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>10</a> times with the same <a href='javascript:editParameter(\"4\", \"3\")' class='dynamic'>Source Address</a> and different <a href='javascript:editParameter(\"4\", \"4\")' class='dynamic'>Destination Address</a> in <a href='javascript:editParameter(\"4\", \"5\")' class='dynamic'>5</a> <a href='javascript:editParameter(\"4\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": "SYSTEM-1201"
            },
            {
              "id": "2",
              "value": "10"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "sourceaddress"
            },
            {
