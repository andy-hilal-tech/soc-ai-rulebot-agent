            {
              "id": "2",
              "method": "getEventRules",
              "value": "aefca8e3-0782-4321-98f0-1ee3497c7a80"
            }
          ]
        },
        {
          "_$": {
            "name": "ThresholdFunction_Test",
            "uid": "1",
            "id": "80"
          },
          "text": [
            "when any of these <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>BB:CategoryDefinition: Authentication Success</a> with the same <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>username</a> more than <a href='javascript:editParameter(\"1\", \"3\")' class='dynamic'>2</a> times, across <a href='javascript:editParameter(\"1\", \"4\")' class='dynamic'>exactly</a> <a href='javascript:editParameter(\"1\", \"5\")' class='dynamic'>1</a> <a href='javascript:editParameter(\"1\", \"6\")' class='dynamic'>destination IP</a> within <a href='javascript:editParameter(\"1\", \"7\")' class='dynamic'>5</a> <a href='javascript:editParameter(\"1\", \"8\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": "SYSTEM-1220"
