            "name": "RuleMatch_Test",
            "uid": "0",
            "id": "46"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>all</a> of the following <a href='javascript:editParameter(\"0\", \"2\")' class='dynamic'>BB:UBA : Common Event Filters</a>"
