        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>(qid = 5002197 and &quot;Service Filename&quot; MATCHES '\\\\\\\\.*' ) or (qid = 5001832 and &quot;Target Object&quot; MATCHES '.*\\\\Services\\\\.*\\\\ImagePath' and &quot;Target Details&quot; MATCHES '\\\\\\\\.*')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
