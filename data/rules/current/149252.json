  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "5",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>(5001832) RegistryEvent (Value Set)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001832"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Registry Key&quot;) LIKE 'HKLM\\System\\CurrentControlSet\\Services\\%' AND LOWER(&quot;Registry Key&quot;) LIKE '%\\Parameters\\ServiceDll'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Registry%20Key%22)%20LIKE%20'HKLM%5CSystem%5CCurrentControlSet%5CServices%5C%25'%20AND%20LOWER(%22Registry%20Key%22)%20LIKE%20'%25%5CParameters%5CServiceDll'|%5B%22LOWER(%5C%22Registry%20Key%5C%22)%20LIKE%20'HKLM%5C%5CSystem%5C%5CCurrentControlSet%5C%5CServices%5C%5C%25'%20AND%20LOWER(%5C%22Registry%20Key%5C%22)%20LIKE%20'%25%5C%5CParameters%5C%5CServiceDll'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Registry Value Data&quot;) LIKE 'c:\\windows\\system32\\spool\\drivers\\x64\\3\\printconfig.dll'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Registry%20Value%20Data%22)%20LIKE%20'c%3A%5Cwindows%5Csystem32%5Cspool%5Cdrivers%5Cx64%5C3%5Cprintconfig.dll'|%5B%22LOWER(%5C%22Registry%20Value%20Data%5C%22)%20LIKE%20'c%3A%5C%5Cwindows%5C%5Csystem32%5C%5Cspool%5C%5Cdrivers%5C%5Cx64%5C%5C3%5C%5Cprintconfig.dll'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) LIKE 'lsass.exe' AND (LOWER(&quot;Registry Key&quot;) LIKE '%\\CurrentControlSet\\Services\\NTDS\\Parameters\\ServiceDll' AND LOWER(&quot;Registry Value Data&quot;) LIKE '%%systemroot%%\\system32\\ntdsa.dll') OR LOWER(&quot;Process Full Full Name&quot;) LIKE 'poqexec.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20LIKE%20'lsass.exe'%20AND%20(LOWER(%22Registry%20Key%22)%20LIKE%20'%25%5CCurrentControlSet%5CServices%5CNTDS%5CParameters%5CServiceDll'%20AND%20LOWER(%22Registry%20Value%20Data%22)%20LIKE%20'%25%25systemroot%25%25%5Csystem32%5Cntdsa.dll')%20OR%20LOWER(%22Process%20Name%22)%20LIKE%20'poqexec.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'lsass.exe'%20AND%20(LOWER(%5C%22Registry%20Key%5C%22)%20LIKE%20'%25%5C%5CCurrentControlSet%5C%5CServices%5C%5CNTDS%5C%5CParameters%5C%5CServiceDll'%20AND%20LOWER(%5C%22Registry%20Value%20Data%5C%22)%20LIKE%20'%25%25systemroot%25%25%5C%5Csystem32%5C%5Cntdsa.dll')%20OR%20LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'poqexec.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
