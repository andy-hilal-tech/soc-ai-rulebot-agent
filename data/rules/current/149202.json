            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>(LOWER(Command) LIKE '%nltest%' AND (LOWER(&quot;Command&quot;) LIKE '%domain_trusts%' OR LOWER(&quot;Command&quot;) LIKE '%all_trusts%' OR LOWER(&quot;Command&quot;) LIKE '%/trusted_domains%' OR LOWER(&quot;Command&quot;) LIKE '%/dclist%')) OR (LOWER(Command) LIKE '%dsquery%' AND LOWER(&quot;Command&quot;) LIKE '%trustedDomain%') OR (LOWER(Command) LIKE '%dsquery%' AND LOWER(&quot;Command&quot;) LIKE '%-filter%' AND LOWER(&quot;Command&quot;) LIKE '%trustedDomain%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(Command)%20LIKE%20'%25nltest%25'%20AND%20(LOWER(%22Command%22)%20LIKE%20'%25domain_trusts%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25all_trusts%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25%2Ftrusted_domains%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25%2Fdclist%25'))%20OR%20(LOWER(Command)%20LIKE%20'%25dsquery%25'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25trustedDomain%25')%20OR%20(LOWER(Command)%20LIKE%20'%25dsquery%25'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25-filter%25'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25trustedDomain%25')|%5B%22(LOWER(Command)%20LIKE%20'%25nltest%25'%20AND%20(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25domain_trusts%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25all_trusts%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%2Ftrusted_domains%25'%20OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%2Fdclist%25'))%20OR%20(LOWER(Command)%20LIKE%20'%25dsquery%25'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25trustedDomain%25')%20OR%20(LOWER(Command)%20LIKE%20'%25dsquery%25'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25-filter%25'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25trustedDomain%25')%22%5D"
