  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001829) ProcessAccess</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001829"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>&quot;Target Process Name&quot; IMATCHES 'lsass\\.exe' and &quot;Granted Access&quot; IMATCHES '(0x1010)|(0x1410)|(0x143A)|(0x1400)|(0x147a)|(0x143a)'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Target%20Process%20Name%22%20IMATCHES%20'lsass%5C.exe'%20and%20%22Granted%20Access%22%20IMATCHES%20'(0x1010)%7C(0x1410)%7C(0x143A)%7C(0x1400)%7C(0x147a)%7C(0x143a)'|%5B%22%5C%22Target%20Process%20Name%5C%22%20IMATCHES%20'lsass%5C%5C.exe'%20and%20%5C%22Granted%20Access%5C%22%20IMATCHES%20'(0x1010)%7C(0x1410)%7C(0x143A)%7C(0x1400)%7C(0x147a)%7C(0x143a)'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>&quot;Call Trace&quot; IMATCHES '.*\\\\Windows\\\\system32\\\\KERNELBASE\\.dll\\+\\w+\\|UNKNOWN.*'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Call%20Trace%22%20IMATCHES%20'.*%5C%5CWindows%5C%5Csystem32%5C%5CKERNELBASE%5C.dll%5C%2B%5Cw%2B%5C%7CUNKNOWN.*'|%5B%22%5C%22Call%20Trace%5C%22%20IMATCHES%20'.*%5C%5C%5C%5CWindows%5C%5C%5C%5Csystem32%5C%5C%5C%5CKERNELBASE%5C%5C.dll%5C%5C%2B%5C%5Cw%2B%5C%5C%7CUNKNOWN.*'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
