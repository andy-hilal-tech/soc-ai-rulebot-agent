  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "3",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "0",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>(5000850) Success Audit: An attempt was made to access an object</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5000850"
            }
          ]
        },
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "4",
            "id": "46"
          },
          "text": [
            "when an event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>all</a> of the following <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>BB:UBA : Common Event Filters</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "all"
            },
            {
              "id": "2",
              "method": "getEventRules",
              "value": "aefca8e3-0782-4321-98f0-1ee3497c7a80"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "1",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>500</a> events are seen with the same <a href='javascript:editParameter(\"1\", \"3\")' class='dynamic'>Username, Process Name (custom)</a> and different <a href='javascript:editParameter(\"1\", \"4\")' class='dynamic'>Object Name (custom)</a> in <a href='javascript:editParameter(\"1\", \"5\")' class='dynamic'>1</a> <a href='javascript:editParameter(\"1\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "500"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "userName, Process Name"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "Object Name"
            },
            {
              "id": "5",
              "value": "1"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "2",
            "id": "107",
            "negate": "true"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>Process Name (custom)</a> are contained in <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>(Shared) UBA : Windows Common Processes - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "61"
            }
          ]
        }
      ]
    }
