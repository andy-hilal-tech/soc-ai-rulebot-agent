      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "3",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>System.Successful Registry Modification, Audit.Object Access Success, System.Process Creation Success, System.Service Installed</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8012, 19081, 8110, 8030"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "2",
            "id": "303"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Service Configured to Use Powershell, Encoded Command Malicious Usage in a Programming Environment, BB:BehaviorDefinition: Administrative Share Accessed, BB:BehaviorDefinition: Programming Environment Started with a Privileged Account</a> match at least <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>4</a> times with the same <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>Destination IP</a> in <a href='javascript:editParameter(\"2\", \"5\")' class='dynamic'>5</a> <a href='javascript:editParameter(\"2\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": "3c17abbf-0797-4dc5-8917-6d4cbc1b4c93, a8da84b4-884c-492e-aa86-bc61aa4301c4, 66067912-26f8-4899-ac0c-1c9c1a259a8c, a138d39e-431a-4911-8db4-8e0966a628a9"
