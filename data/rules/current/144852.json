          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) MATCHES '(excel|mspub|onenote|onenoteim|outlook|powerpnt|winword)\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20MATCHES%20'(excel%7Cmspub%7Conenote%7Conenoteim%7Coutlook%7Cpowerpnt%7Cwinword)%5C.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20MATCHES%20'(excel%7Cmspub%7Conenote%7Conenoteim%7Coutlook%7Cpowerpnt%7Cwinword)%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
