          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;File Directory&quot;) MATCHES 'c:\\\\windows\\\\assembly\\\\.*'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22File%20Directory%22)%20MATCHES%20'c%3A%5C%5Cwindows%5C%5Cassembly%5C%5C.*'|%5B%22LOWER(%5C%22File%20Directory%5C%22)%20MATCHES%20'c%3A%5C%5C%5C%5Cwindows%5C%5C%5C%5Cassembly%5C%5C%5C%5C.*'%22%5D"
            },
