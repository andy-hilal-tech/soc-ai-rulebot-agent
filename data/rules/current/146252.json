  "rule_name": "Hiding Files with Attrib",
  "object_type": "rule",
  "group": "Turla, Endpoint",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2023-03-23T08:03:07.137Z",
  "modified": "2024-07-21T12:38:25.067Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "5",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) == 'attrib.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20%3D%3D%20'attrib.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20%3D%3D%20'attrib.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Command&quot;) LIKE '% +h %'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20LIKE%20'%25%20%2Bh%20%25'|%5B%22LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20%2Bh%20%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Command&quot;) LIKE '%\\desktop.ini %' OR (LOWER(&quot;Parent Process Full Full Name&quot;) LIKE '%cmd.exe' AND LOWER(&quot;Command&quot;) LIKE '+R +H +S +A \\\\%.cui' AND LOWER(&quot;Command&quot;) LIKE 'C:\\\\WINDOWS\\\\system32\\\\%.bat')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20LIKE%20'%25%5Cdesktop.ini%20%25'%20OR%20(LOWER(%22Parent%20Process%20Name%22)%20LIKE%20'%25cmd.exe'%20AND%20LOWER(%22Command%22)%20LIKE%20'%2BR%20%2BH%20%2BS%20%2BA%20%5C%5C%25.cui'%20AND%20LOWER(%22Command%22)%20LIKE%20'C%3A%5C%5CWINDOWS%5C%5Csystem32%5C%5C%25.bat')|%5B%22LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%5C%5Cdesktop.ini%20%25'%20OR%20(LOWER(%5C%22Parent%20Process%20Name%5C%22)%20LIKE%20'%25cmd.exe'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%2BR%20%2BH%20%2BS%20%2BA%20%5C%5C%5C%5C%25.cui'%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'C%3A%5C%5C%5C%5CWINDOWS%5C%5C%5C%5Csystem32%5C%5C%5C%5C%25.bat')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "_$": {
        "flowAnalysisInterval": "0",
        "includeAttackerEventsInterval": "0",
        "forceOffenseCreation": "true",
        "offenseMapping": "0"
      }
    }
  ],
  "dependencies": [],
