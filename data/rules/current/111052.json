  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001828) Process Create, (5000862) Success Audit: A new process has been created</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828,                                                                                                                                                                                                                                                                                       5000862"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Process Name IMATCHES 'sc\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Process%20Name%22%20IMATCHES%20'sc%5C.exe'|%5B%22%5C%22Process%20Name%5C%22%20IMATCHES%20'sc%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "3",
            "id": "300"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>25</a> events are seen with the same <a href='javascript:editParameter(\"3\", \"3\")' class='dynamic'>Source IP</a> in <a href='javascript:editParameter(\"3\", \"5\")' class='dynamic'>3</a> <a href='javascript:editParameter(\"3\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "25"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "sourceIP"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": " "
            },
            {
              "id": "5",
              "value": "3"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        }
      ]
    }
  ],
