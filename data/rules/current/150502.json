              "id": "1",
              "value": "LOWER(%22Command%20Arguments%22)%20MATCHES%20'.*%3Fa0%3D%5C%22(users%7Cw%7Cwho)%5C%22.*%3F'|%5B%22LOWER(%5C%22Command%20Arguments%5C%22)%20MATCHES%20'.*%3Fa0%3D%5C%5C%5C%22(users%7Cw%7Cwho)%5C%5C%5C%22.*%3F'%22%5D"
