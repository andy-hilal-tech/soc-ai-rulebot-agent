  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success, Audit.Command Execution Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 19250"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>((&quot;Command&quot; LIKE '%Get-AdGroup %' OR &quot;Command&quot; LIKE '%Get-AdComputer %') AND &quot;Command&quot; LIKE '%-Filter%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "((%22Command%22%20LIKE%20'%25Get-AdGroup%20%25'%20OR%20%22Command%22%20LIKE%20'%25Get-AdComputer%20%25')%20AND%20%22Command%22%20LIKE%20'%25-Filter%25')|%5B%22((%5C%22Command%5C%22%20LIKE%20'%25Get-AdGroup%20%25'%20OR%20%5C%22Command%5C%22%20LIKE%20'%25Get-AdComputer%20%25')%20AND%20%5C%22Command%5C%22%20LIKE%20'%25-Filter%25')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
