  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "AttackContext_Test",
            "uid": "0",
            "id": "25"
          },
          "text": [
            "when the context is <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Local to Remote</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "l2r"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "1",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"1\", \"2\")' class='dynamic'>Destination IP</a> are contained in <a href='javascript:editParameter(\"1\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"1\", \"4\")' class='dynamic'>Anonymizer IPs - IP, XFE ATPF-anonsvcs_ipv4 - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getCommonDatabaseFields",
              "value": "destinationIP"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "272, 291"
            }
          ]
        }
      ]
    }
  ],
