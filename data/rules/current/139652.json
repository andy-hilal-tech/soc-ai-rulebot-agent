  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "1",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "0",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>System.File Deleted</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8033"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "4",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>25</a> events are seen with the same <a href='javascript:editParameter(\"4\", \"3\")' class='dynamic'>Machine Identifier (custom)</a> and different <a href='javascript:editParameter(\"4\", \"4\")' class='dynamic'>File Directory (custom)</a> in <a href='javascript:editParameter(\"4\", \"5\")' class='dynamic'>5</a> <a href='javascript:editParameter(\"4\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "25"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "Machine Identifier"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "File Directory"
            },
            {
              "id": "5",
              "value": "5"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        }
      ]
    }
  ],
