  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) MATCHES '(powershell|pwsh|wmic|vssadmin)\\.exe' OR Filename MATCHES '%PowerShell.EXE|pwsh.dll|wmic.exe|VSSADMIN.EXE%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20MATCHES%20'(powershell%7Cpwsh%7Cwmic%7Cvssadmin)%5C.exe'%20OR%20Filename%20MATCHES%20'%25PowerShell.EXE%7Cpwsh.dll%7Cwmic.exe%7CVSSADMIN.EXE%25'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20MATCHES%20'(powershell%7Cpwsh%7Cwmic%7Cvssadmin)%5C%5C.exe'%20OR%20Filename%20MATCHES%20'%25PowerShell.EXE%7Cpwsh.dll%7Cwmic.exe%7CVSSADMIN.EXE%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Command (custom) contains all of [shadow or create]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "CommandCONALLanyshadow�create"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
