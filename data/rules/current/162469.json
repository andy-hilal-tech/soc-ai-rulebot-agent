  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.File Created</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8028"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) MATCHES '(winword|excel|powerpnt)\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20MATCHES%20'(winword%7Cexcel%7Cpowerpnt)%5C.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20MATCHES%20'(winword%7Cexcel%7Cpowerpnt)%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>File Extension (custom) is any of [exe or dll or ocx or com or ps1 or vbs or sys or bat or scr or proj or vba or jse or vbe or js]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "File ExtensionEQanyexe�dll�ocx�com�ps1�vbs�sys�bat�scr�proj�vba�jse�vbe�js"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>(LOWER(&quot;Target File Directory&quot;) LIKE 'c:\\users\\%' and LOWER(&quot;Target File Directory&quot;) LIKE '%\\appdata\\local\\microsoft\\office\\%' and LOWER(&quot;Target File Directory&quot;) LIKE '%\\webservicecache\\allusers%') and LOWER(&quot;File Extension&quot;) LIKE 'com'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(%22Target%20File%20Directory%22)%20LIKE%20'c%3A%5Cusers%5C%25'%20and%20LOWER(%22Target%20File%20Directory%22)%20LIKE%20'%25%5Cappdata%5Clocal%5Cmicrosoft%5Coffice%5C%25'%20and%20LOWER(%22Target%20File%20Directory%22)%20LIKE%20'%25%5Cwebservicecache%5Callusers%25')%20and%20LOWER(%22File%20Extension%22)%20LIKE%20'com'|%5B%22(LOWER(%5C%22Target%20File%20Directory%5C%22)%20LIKE%20'c%3A%5C%5Cusers%5C%5C%25'%20and%20LOWER(%5C%22Target%20File%20Directory%5C%22)%20LIKE%20'%25%5C%5Cappdata%5C%5Clocal%5C%5Cmicrosoft%5C%5Coffice%5C%5C%25'%20and%20LOWER(%5C%22Target%20File%20Directory%5C%22)%20LIKE%20'%25%5C%5Cwebservicecache%5C%5Callusers%25')%20and%20LOWER(%5C%22File%20Extension%5C%22)%20LIKE%20'com'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "5",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) LIKE 'winword.exe' and LOWER(&quot;Target File Directory&quot;) LIKE '%\\appdata\\local\\temp\\webexdelta\\%' and (LOWER(&quot;File Extension&quot;) LIKE 'dll' or LOWER(&quot;File Extension&quot;) LIKE 'exe')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20LIKE%20'winword.exe'%20and%20LOWER(%22Target%20File%20Directory%22)%20LIKE%20'%25%5Cappdata%5Clocal%5Ctemp%5Cwebexdelta%5C%25'%20and%20(LOWER(%22File%20Extension%22)%20LIKE%20'dll'%20or%20LOWER(%22File%20Extension%22)%20LIKE%20'exe')|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'winword.exe'%20and%20LOWER(%5C%22Target%20File%20Directory%5C%22)%20LIKE%20'%25%5C%5Cappdata%5C%5Clocal%5C%5Ctemp%5C%5Cwebexdelta%5C%5C%25'%20and%20(LOWER(%5C%22File%20Extension%5C%22)%20LIKE%20'dll'%20or%20LOWER(%5C%22File%20Extension%5C%22)%20LIKE%20'exe')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "6",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"6\", \"1\")' class='dynamic'>LOWER(&quot;Target File Directory&quot;) LIKE '%\\appdata\\local\\assembly\\tmp\\%' and LOWER(&quot;File Extension&quot;) LIKE 'dll'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Target%20File%20Directory%22)%20LIKE%20'%25%5Cappdata%5Clocal%5Cassembly%5Ctmp%5C%25'%20and%20LOWER(%22File%20Extension%22)%20LIKE%20'dll'|%5B%22LOWER(%5C%22Target%20File%20Directory%5C%22)%20LIKE%20'%25%5C%5Cappdata%5C%5Clocal%5C%5Cassembly%5C%5Ctmp%5C%5C%25'%20and%20LOWER(%5C%22File%20Extension%5C%22)%20LIKE%20'dll'%22%5D"
            },
