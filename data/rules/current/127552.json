  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "AttackContext_Test",
            "uid": "1",
            "id": "25"
          },
          "text": [
            "when the context is <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Local to Remote</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "l2r"
            }
          ]
        },
        {
          "_$": {
            "name": "RuleMatch_Test",
            "uid": "0",
            "id": "46"
          },
          "text": [
            "when a flow or an event matches <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>any</a> of the following <a href='javascript:editParameter(\"0\", \"2\")' class='dynamic'>BB:CategoryDefinition: Firewall or ACL Accept, BB:CategoryDefinition: Successful Communication, BB:DeviceDefinition: FW / Router / Switch</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getCommonRules",
              "value": "SYSTEM-1208, SYSTEM-1472, SYSTEM-1322"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "2",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>50</a> events or flows are seen with the same <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>Source IP</a> and different <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Destination Port</a> in <a href='javascript:editParameter(\"2\", \"5\")' class='dynamic'>1</a> <a href='javascript:editParameter(\"2\", \"6\")' class='dynamic'>hour(s)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCommonRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "50"
            },
            {
              "id": "3",
              "method": "getCommonDatabaseFields",
              "value": "sourceIP"
            },
            {
              "id": "4",
              "method": "getCommonDatabaseFields",
              "value": "destinationPort"
            },
            {
              "id": "5",
              "value": "1"
            },
            {
              "id": "6",
              "value": "h"
            }
          ]
        }
      ]
    }
