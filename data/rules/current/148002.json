  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "2",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>System.Process Creation Success, Audit.Object Load Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 19247"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>&quot;Process Full Full Name&quot; is not NULL</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Process%20Name%22%20is%20not%20NULL|%5B%22%5C%22Process%20Name%5C%22%20is%20not%20NULL%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>( \tLOWER(&quot;Process Full Full Name&quot;) LIKE 'tshark.exe' \tAND LOWER(&quot;Command&quot;) LIKE '% -i %' ) OR LOWER(&quot;Process Full Full Name&quot;) LIKE 'windump.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(%20%09LOWER(%22Process%20Name%22)%20LIKE%20'tshark.exe'%20%09AND%20LOWER(%22Command%22)%20LIKE%20'%25%20-i%20%25'%20)%20OR%20LOWER(%22Process%20Name%22)%20LIKE%20'windump.exe'|%5B%22(%22%2C%22%5CtLOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'tshark.exe'%22%2C%22%5CtAND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20-i%20%25'%22%2C%22)%22%2C%22OR%22%2C%22LOWER(%5C%22Process%20Name%5C%22)%20LIKE%20'windump.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
