        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>&quot;Command&quot; IMATCHES '(.*vssadmin.exe\\s*Delete\\s*Shadows.*)|(wmic\\.exe.*shadowcopy\\s*delete.*)'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Command%22%20IMATCHES%20'(.*vssadmin.exe%5Cs*Delete%5Cs*Shadows.*)%7C(wmic%5C.exe.*shadowcopy%5Cs*delete.*)'|%5B%22%5C%22Command%5C%22%20IMATCHES%20'(.*vssadmin.exe%5C%5Cs*Delete%5C%5Cs*Shadows.*)%7C(wmic%5C%5C.exe.*shadowcopy%5C%5Cs*delete.*)'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
