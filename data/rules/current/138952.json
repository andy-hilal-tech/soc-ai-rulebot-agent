  "rule_name": "Service Configured to Use Powershell",
  "object_type": "rule",
  "group": "Endpoint, Windows",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2017-09-10T23:42:35.030Z",
  "modified": "2024-07-21T10:28:49.577Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "3",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>System.Service Installed, System.Successful Registry Modification</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8030, 8012"
            }
          ]
        },
        {
          "_$": {
            "name": "PropertyRegex",
            "uid": "2",
            "id": "225"
          },
          "text": [
            "when any of <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Service Filename (custom), Registry Value Data (custom)</a> match <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>(?i).*powershell.*</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventDatabaseFields",
              "value": "Service Filename, Registry Value Data"
            },
            {
              "id": "2",
              "value": "(?i).*powershell.*"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "_$": {
        "flowAnalysisInterval": "0",
        "includeAttackerEventsInterval": "0",
        "forceOffenseCreation": "true",
        "offenseMapping": "0"
      },
