  "rule_name": "Suspicious Number of Same User Logins to Multiple Devices",
  "object_type": "rule",
  "group": "Anomaly",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "OVERRIDE",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2024-11-29T07:09:02.675Z",
