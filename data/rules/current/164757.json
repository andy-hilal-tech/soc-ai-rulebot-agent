  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "0",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Authentication.User Login Success, Authentication.User Login Attempt, Authentication.Admin Login Attempt, Authentication.Admin Login Successful</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "3115, 3114, 3113, 3014"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "2",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>10</a> events are seen with the same <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>Username</a> and different <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Log Source</a> in <a href='javascript:editParameter(\"2\", \"5\")' class='dynamic'>5</a> <a href='javascript:editParameter(\"2\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "10"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "userName"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "device"
            },
            {
              "id": "5",
              "value": "5"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        }
      ]
    }
  ],
