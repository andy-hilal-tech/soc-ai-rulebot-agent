        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "2",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>Destination IP</a> are contained in <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Critical Assets - IP</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "destinationIP"
