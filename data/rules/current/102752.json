              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "21"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceDataTest",
            "uid": "3",
            "id": "110",
            "negate": "false"
          },
          "text": [
            "when <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>Destination IP</a> is the key and <a href='javascript:editParameter(\"3\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"4\")' class='dynamic'>Username</a> is the value in <a href='javascript:editParameter(\"3\", \"5\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"6\")' class='dynamic'>Critical Systems Users Seen - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "destinationIP"
