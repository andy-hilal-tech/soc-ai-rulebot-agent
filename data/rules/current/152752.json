)%20LIKE%20'dxdiag.exe'%20or%20LOWER(%5C%22Target%20Process%20Name%5C%22)%20LIKE%20'mobsync.exe'%20or%20LOWER(%5C%22Target%20Process%20Name%5C%22)%20LIKE%20'msra.exe'%20or%20LOWER(%5C%22Target%20Process%20Name%5C%22)%20LIKE%20'xwizard.exe'%22%5D"
