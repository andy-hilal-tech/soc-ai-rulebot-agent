          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "102"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "2",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Process Name (custom) contains any of [rm or unlink or shred]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process NameCONanyrm�unlink�shred"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Command (custom) contains any of [/var/log or /Library/Logs/], Process Path (custom) contains any of [/Library/Logs/ or /var/log]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "CommandCONany/var/log�/Library/Logs/Process PathCONany/Library/Logs/�/var/log"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
