  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success, Audit.Command Execution Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 19250"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>(     LOWER(&quot;Command&quot;) LIKE '%cmd.exe /c%'     AND LOWER(&quot;Command&quot;) LIKE '%roamdiag.cmd%'     AND LOWER(&quot;Command&quot;) LIKE '%-outputpath%' )</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(%20%20%20%20%20LOWER(%22Command%22)%20LIKE%20'%25cmd.exe%20%2Fc%25'%20%20%20%20%20AND%20LOWER(%22Command%22)%20LIKE%20'%25roamdiag.cmd%25'%20%20%20%20%20AND%20LOWER(%22Command%22)%20LIKE%20'%25-outputpath%25'%20)|%5B%22(%22,%22%20%20%20%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25cmd.exe%20%2Fc%25'%22,%22%20%20%20%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25roamdiag.cmd%25'%22,%22%20%20%20%20AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25-outputpath%25'%22,%22)%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(LOWER(&quot;Process File File Path&quot;) LIKE 'C:\\Windows\\System32\\%' OR LOWER(&quot;Process File File Path&quot;) LIKE 'C:\\Windows\\SysWOW64\\%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(%22Process%20Path%22)%20LIKE%20'C%3A%5CWindows%5CSystem32%5C%25'%20OR%20LOWER(%22Process%20Path%22)%20LIKE%20'C%3A%5CWindows%5CSysWOW64%5C%25')|%5B%22(LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'C%3A%5C%5CWindows%5C%5CSystem32%5C%5C%25'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'C%3A%5C%5CWindows%5C%5CSysWOW64%5C%5C%25')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
