  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success, System.Service Installed</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 8030"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Service Full Name Full Full Name Full Full Name&quot;) == 'hybridconnectionmanager' AND LOWER(&quot;Service Full Name Full Full Name Filename&quot;) == 'hybridconnectionmanager'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Service%20Name%22)%20%3D%3D%20'hybridconnectionmanager'%20AND%20LOWER(%22Service%20Filename%22)%20%3D%3D%20'hybridconnectionmanager'|%5B%22LOWER(%5C%22Service%20Name%5C%22)%20%3D%3D%20'hybridconnectionmanager'%22%2C%22AND%20LOWER(%5C%22Service%20Filename%5C%22)%20%3D%3D%20'hybridconnectionmanager'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
