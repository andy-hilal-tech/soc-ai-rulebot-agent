          "parameter": [
            {
              "id": "1",
              "value": "(sourceport%3D%3D3389%20and%20(str(destinationaddress)%20matches%20'127.*'%20or%20str(destinationaddress)%20matches%20'%3A%3A1'))%20OR%20(destinationport%20%3D%3D%203389%20and%20(str(sourceaddress)%20matches%20'127.*'%20or%20str(sourceaddress)%20matches%20'%3A%3A1'))|%5B%22(sourceport%3D%3D3389%20and%20(str(destinationaddress)%20matches%20'127.*'%20or%20str(destinationaddress)%20matches%20'%3A%3A1'))%22,%22OR%22,%22(destinationport%20%3D%3D%203389%20and%20(str(sourceaddress)%20matches%20'127.*'%20or%20str(sourceaddress)%20matches%20'%3A%3A1'))%22%5D"
