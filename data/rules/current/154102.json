          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(LOWER(&quot;Process Full Full Name&quot;) LIKE '%thor.exe' OR LOWER(&quot;Process Full Full Name&quot;) LIKE '%thor64.exe')</a> AQL filter query"
