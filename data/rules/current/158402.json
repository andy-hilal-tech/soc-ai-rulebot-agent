            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>( \tLOWER(&quot;Parent Process Full Full Name&quot;) in ('winlogon.exe', 'services.exe', 'lsass.exe', 'csrss.exe', 'smss.exe', 'wininit.exe', 'spoolsv.exe', 'searchindexer.exe') \tAND LOWER(Username) in ('authori', 'autori') ) AND  ( \tLOWER(&quot;Process Full Full Name&quot;) in ('powershell.exe', 'pwsh.exe', 'cmd.exe') \tOR LOWER(&quot;Filename&quot;) in ('powershell.exe', 'pwsh.dll', 'cmd.exe') )</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(%20%09LOWER(%22Parent%20Process%20Name%22)%20in%20('winlogon.exe'%2C%20'services.exe'%2C%20'lsass.exe'%2C%20'csrss.exe'%2C%20'smss.exe'%2C%20'wininit.exe'%2C%20'spoolsv.exe'%2C%20'searchindexer.exe')%20%09AND%20LOWER(Username)%20in%20('authori'%2C%20'autori')%20)%20AND%20%20(%20%09LOWER(%22Process%20Name%22)%20in%20('powershell.exe'%2C%20'pwsh.exe'%2C%20'cmd.exe')%20%09OR%20LOWER(%22Filename%22)%20in%20('powershell.exe'%2C%20'pwsh.dll'%2C%20'cmd.exe')%20)|%5B%22(%22%2C%22%5CtLOWER(%5C%22Parent%20Process%20Name%5C%22)%20in%20('winlogon.exe'%2C%20'services.exe'%2C%20'lsass.exe'%2C%20'csrss.exe'%2C%20'smss.exe'%2C%20'wininit.exe'%2C%20'spoolsv.exe'%2C%20'searchindexer.exe')%22%2C%22%5CtAND%20LOWER(Username)%20in%20('authori'%2C%20'autori')%22%2C%22)%22%2C%22AND%20%22%2C%22(%22%2C%22%5CtLOWER(%5C%22Process%20Name%5C%22)%20in%20('powershell.exe'%2C%20'pwsh.exe'%2C%20'cmd.exe')%22%2C%22%5CtOR%20LOWER(%5C%22Filename%5C%22)%20in%20('powershell.exe'%2C%20'pwsh.dll'%2C%20'cmd.exe')%22%2C%22)%22%5D"
