            "name": "AQL_Test",
            "uid": "1",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>LOWER(&quot;Command&quot;) LIKE '% route %' AND LOWER(&quot;Command&quot;) LIKE '% add %'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20LIKE%20'%25%20route%20%25'%20AND%20LOWER(%22Command%22)%20LIKE%20'%25%20add%20%25'|%5B%22LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20route%20%25'%22,%22AND%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20add%20%25'%22%5D"
            },
