  "uuid": "904ad1ac-aea9-4332-9c5f-b2aeab756bd2",
  "rule_name": "System Process Launched from Unusual Directory",
  "object_type": "rule",
  "group": "Sysmon",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2017-08-13T23:21:50.520Z",
  "modified": "2024-02-19T16:49:25.879Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "3",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(5001828) Process Create, (5000862) Success Audit: A new process has been created</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828,                                                                                                                                                                                                                                                                                                               5000862"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Process Name IMATCHES '((smss)|(wininit)|(taskhost)|(lsass)|(winlogon)|(explorer)|(lsm)|(svchost)|(services)|(csrss)|(cmd)|(iexplore))\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Process%20Name%22%20IMATCHES%20'((smss)%7C(wininit)%7C(taskhost)%7C(lsass)%7C(winlogon)%7C(explorer)%7C(lsm)%7C(svchost)%7C(services)%7C(csrss)%7C(cmd)%7C(iexplore))%5C.exe'|%5B%22%5C%22Process%20Name%5C%22%20IMATCHES%20'((smss)%7C(wininit)%7C(taskhost)%7C(lsass)%7C(winlogon)%7C(explorer)%7C(lsm)%7C(svchost)%7C(services)%7C(csrss)%7C(cmd)%7C(iexplore))%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>REFERENCEMAPSETCONTAINS('ProcessMaptoProcessPath', LOWER(&quot;Process Name&quot;), LOWER(&quot;Process Path&quot;)) != True</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "REFERENCEMAPSETCONTAINS('ProcessMaptoProcessPath'%2C%20LOWER(%22Process%20Name%22)%2C%20LOWER(%22Process%20Path%22))%20!%3D%20True|%5B%22REFERENCEMAPSETCONTAINS('ProcessMaptoProcessPath'%2C%20LOWER(%5C%22Process%20Name%5C%22)%2C%20LOWER(%5C%22Process%20Path%5C%22))%20!%3D%20True%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "_$": {
        "flowAnalysisInterval": "0",
        "includeAttackerEventsInterval": "0",
        "forceOffenseCreation": "true",
        "offenseMapping": "0"
      }
    }
  ],
  "dependencies": [],
  "limiter": [
    {
      "_$": {
        "hostType": "IMAGENAME",
        "intervalType": "m",
        "intervalCount": "30",
        "responseCount": "1"
      }
    }
  ],
