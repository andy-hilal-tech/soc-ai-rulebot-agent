          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process NameEQanynet.exe�net1.exe"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
