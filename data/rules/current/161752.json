          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20LIKE%20'%25stop%25'%20AND%20%20(%20%09LOWER(%22Command%22)%20LIKE%20'%25samss%25'%20%09OR%20LOWER(%22Command%22)%20LIKE%20'%25audioendpointbuilder%25'%20%09OR%20LOWER(%22Command%22)%20LIKE%20'%25unistoresvc_%25'%20)|%5B%22LOWER(%5C%22Command%5C%22)%20LIKE%20'%25stop%25'%22,%22AND%20%22,%22(%22,%22%5CtLOWER(%5C%22Command%5C%22)%20LIKE%20'%25samss%25'%22,%22%5CtOR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25audioendpointbuilder%25'%22,%22%5CtOR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25unistoresvc_%25'%22,%22)%22%5D"
