  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success, Audit.Command Execution Success, Audit.Object Load Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 19250, 19247"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Description&quot;) LIKE '%python core%' AND  ( \tLOWER(&quot;Process Full Full Name&quot;) NOT LIKE '%python%' \tAND LOWER(&quot;Process Full Full Name&quot;) NOT LIKE '%c:\\program files\\%' \tAND LOWER(&quot;Process Full Full Name&quot;) NOT LIKE '%c:\\program files (x86)\\%' \tAND LOWER(&quot;Process Full Full Name&quot;) NOT LIKE '%c:\\programdata\\anaconda3\\%' )</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Description%22)%20LIKE%20'%25python%20core%25'%20AND%20%20(%20%09LOWER(%22Process%20Name%22)%20NOT%20LIKE%20'%25python%25'%20%09AND%20LOWER(%22Process%20Name%22)%20NOT%20LIKE%20'%25c%3A%5Cprogram%20files%5C%25'%20%09AND%20LOWER(%22Process%20Name%22)%20NOT%20LIKE%20'%25c%3A%5Cprogram%20files%20(x86)%5C%25'%20%09AND%20LOWER(%22Process%20Name%22)%20NOT%20LIKE%20'%25c%3A%5Cprogramdata%5Canaconda3%5C%25'%20)|%5B%22LOWER(%5C%22Description%5C%22)%20LIKE%20'%25python%20core%25'%22%2C%22AND%20%22%2C%22(%22%2C%22%5CtLOWER(%5C%22Process%20Name%5C%22)%20NOT%20LIKE%20'%25python%25'%22%2C%22%5CtAND%20LOWER(%5C%22Process%20Name%5C%22)%20NOT%20LIKE%20'%25c%3A%5C%5Cprogram%20files%5C%5C%25'%22%2C%22%5CtAND%20LOWER(%5C%22Process%20Name%5C%22)%20NOT%20LIKE%20'%25c%3A%5C%5Cprogram%20files%20(x86)%5C%5C%25'%22%2C%22%5CtAND%20LOWER(%5C%22Process%20Name%5C%22)%20NOT%20LIKE%20'%25c%3A%5C%5Cprogramdata%5C%5Canaconda3%5C%5C%25'%22%2C%22)%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
