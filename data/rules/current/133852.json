  "rule_name": "Impair Command History Logging Activity Detected",
  "object_type": "rule",
  "group": "Endpoint",
  "rule_category": "Custom Rule",
  "type": "EVENT",
  "origin": "SYSTEM",
  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2023-05-17T13:09:17.879Z",
  "modified": "2024-07-21T10:28:52.974Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success, Exploit.Command Execution, Audit.Command Execution Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110, 5034, 19250"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Process Name&quot;) == 'powershell.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20%3D%3D%20'powershell.exe'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20%3D%3D%20'powershell.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Command&quot;) LIKE '%psreadline%'  OR LOWER(&quot;Command&quot;) LIKE '%consolehost_history.txt%' OR LOWER(&quot;Command&quot;) LIKE '%set-psreadlineoption -historysavestyle savenothing%' OR LOWER(&quot;Command&quot;) LIKE '%set-psreadlineoption -historysavepath%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Command%22)%20LIKE%20'%25psreadline%25'%20%20OR%20LOWER(%22Command%22)%20LIKE%20'%25consolehost_history.txt%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25set-psreadlineoption%20-historysavestyle%20savenothing%25'%20OR%20LOWER(%22Command%22)%20LIKE%20'%25set-psreadlineoption%20-historysavepath%25'|%5B%22LOWER(%5C%22Command%5C%22)%20LIKE%20'%25psreadline%25'%20%22,%22OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25consolehost_history.txt%25'%22,%22OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25set-psreadlineoption%20-historysavestyle%20savenothing%25'%22,%22OR%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25set-psreadlineoption%20-historysavepath%25'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
