  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Process Name&quot;) MATCHES '(net1|net|taskkill|sc|powershell|kill)\\.(exe|bat)'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20MATCHES%20'(net1%7Cnet%7Ctaskkill%7Csc%7Cpowershell%7Ckill)%5C.(exe%7Cbat)'|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20MATCHES%20'(net1%7Cnet%7Ctaskkill%7Csc%7Cpowershell%7Ckill)%5C%5C.(exe%7Cbat)'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "4",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"4\", \"2\")' class='dynamic'>Terminated Process Name (custom)</a> are contained in <a href='javascript:editParameter(\"4\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"4\", \"4\")' class='dynamic'>Ryuk Service and Process Termination List - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Terminated Process Name"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "237"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "3",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>3</a> events are seen with the same <a href='javascript:editParameter(\"3\", \"3\")' class='dynamic'>Process Name (custom)</a> and different <a href='javascript:editParameter(\"3\", \"4\")' class='dynamic'>Terminated Process Name (custom)</a> in <a href='javascript:editParameter(\"3\", \"5\")' class='dynamic'>5</a> <a href='javascript:editParameter(\"3\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "3"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "Terminated Process Name"
            },
            {
              "id": "5",
              "value": "5"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        }
      ]
    }
