        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320",
            "negate": "false"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) LIKE '%iodine.exe' OR LOWER(&quot;Process Full Full Name&quot;) LIKE '%dnscat2%'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
