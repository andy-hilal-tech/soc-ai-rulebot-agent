  "enabled": false,
  "response": "Dispatch New Event",
  "created": "2017-10-13T13:38:12.720Z",
  "modified": "2024-02-19T16:49:24.345Z",
  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "3",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>(5001830) FileCreate</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001830"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "1",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Process Name IMATCHES '((psexesvc)|(wsmprovhost)|(wmiprvse))\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Process%20Name%22%20IMATCHES%20'((psexesvc)%7C(wsmprovhost)%7C(wmiprvse))%5C.exe'|%5B%22%5C%22Process%20Name%5C%22%20IMATCHES%20'((psexesvc)%7C(wsmprovhost)%7C(wmiprvse))%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>&quot;Filename&quot; IMATCHES '.*\\.(ps|psm)1'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Filename%22%20IMATCHES%20'.*%5C.(ps%7Cpsm)1'|%5B%22%5C%22Filename%5C%22%20IMATCHES%20'.*%5C%5C.(ps%7Cpsm)1'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "_$": {
