  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.File Created, System.Successful File Modification</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8028, 8014"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "3",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Filename (custom) is any of ntds.dit</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "FilenameEQanyntds.dit"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Process Full Full Name&quot;) MATCHES '(cmd|powershell|pwsh|mshta|(w|c)script|wsl).exe'  or (LOWER(&quot;Process File File Path&quot;) LIKE '%\\appdata\\%' or LOWER(&quot;Process File File Path&quot;) LIKE '%\\temp\\%' or LOWER(&quot;Process File File Path&quot;) LIKE '%\\public\\%' or LOWER(&quot;Process File File Path&quot;) LIKE '%\\perflogs\\%')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20MATCHES%20'(cmd%7Cpowershell%7Cpwsh%7Cmshta%7C(w%7Cc)script%7Cwsl).exe'%20%20or%20(LOWER(%22Process%20Path%22)%20LIKE%20'%25%5Cappdata%5C%25'%20or%20LOWER(%22Process%20Path%22)%20LIKE%20'%25%5Ctemp%5C%25'%20or%20LOWER(%22Process%20Path%22)%20LIKE%20'%25%5Cpublic%5C%25'%20or%20LOWER(%22Process%20Path%22)%20LIKE%20'%25%5Cperflogs%5C%25')|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20MATCHES%20'(cmd%7Cpowershell%7Cpwsh%7Cmshta%7C(w%7Cc)script%7Cwsl).exe'%20%22%2C%22or%20(LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'%25%5C%5Cappdata%5C%5C%25'%20or%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'%25%5C%5Ctemp%5C%5C%25'%20or%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'%25%5C%5Cpublic%5C%5C%25'%20or%20LOWER(%5C%22Process%20Path%5C%22)%20LIKE%20'%25%5C%5Cperflogs%5C%5C%25')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
