  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001828) Process Create</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceSetTest",
            "uid": "2",
            "id": "107"
          },
          "text": [
            "when <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>Process Name (custom)</a> are contained in <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>ProcessNametoHashRefMapOfSetKeys - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getReferenceSets",
              "value": "67"
            }
          ]
        },
        {
          "_$": {
            "name": "ReferenceDataTest",
            "uid": "3",
            "id": "110",
            "negate": "true"
          },
          "text": [
            "when <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"2\")' class='dynamic'>Process Name (custom)</a> is the key and <a href='javascript:editParameter(\"3\", \"3\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"4\")' class='dynamic'>File Hash (custom)</a> is the value in <a href='javascript:editParameter(\"3\", \"5\")' class='dynamic'>any</a> of <a href='javascript:editParameter(\"3\", \"6\")' class='dynamic'>ProcessNametoHash - AlphaNumeric (Ignore Case)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "any"
            },
            {
              "id": "2",
              "method": "getEventDatabaseFields",
              "value": "Process Name"
            },
            {
              "id": "3",
              "value": "any"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "File Hash"
            },
            {
              "id": "5",
              "value": "any"
            },
            {
              "id": "6",
              "method": "getReferenceDataMapsOfSets",
              "value": "76"
            }
          ]
        }
      ]
    }
  ],
