  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Amazon AWS CloudTrail, Microsoft Azure Active Directory</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "347, 445"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "3",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>Authentication.User Login Failure</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "3116"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "1",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>Error Code (custom) is any of [Failure or Failed authentication or 50126]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Error CodeEQanyFailure�Failed authentication�50126"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "2",
            "id": "301"
          },
          "text": [
            "when at least <a href='javascript:editParameter(\"2\", \"2\")' class='dynamic'>25</a> events are seen with the same <a href='javascript:editParameter(\"2\", \"3\")' class='dynamic'>Destination IP</a> and different <a href='javascript:editParameter(\"2\", \"4\")' class='dynamic'>Source IP</a> in <a href='javascript:editParameter(\"2\", \"5\")' class='dynamic'>2</a> <a href='javascript:editParameter(\"2\", \"6\")' class='dynamic'>minutes</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getEventRules",
              "value": " "
            },
            {
              "id": "2",
              "value": "25"
            },
            {
              "id": "3",
              "method": "getEventDatabaseFields",
              "value": "destinationIP"
            },
            {
              "id": "4",
              "method": "getEventDatabaseFields",
              "value": "sourceIP"
            },
            {
              "id": "5",
              "value": "2"
            },
            {
              "id": "6",
              "value": "m"
            }
          ]
        }
      ]
    }
