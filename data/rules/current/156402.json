  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "5",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>(5001832) RegistryEvent (Value Set)</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001832"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Registry Key&quot;) MATCHES '.*\\\\system\\\\(controlset001|controlset002|currentcontrolset)\\\\services\\\\.*\\\\servicedll' OR LOWER(&quot;Registry Key&quot;) MATCHES '.*\\\\system\\\\(controlset001|controlset002|currentcontrolset)\\\\services\\\\.*\\\\imagepath'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Registry%20Key%22)%20MATCHES%20'.*%5C%5Csystem%5C%5C(controlset001%7Ccontrolset002%7Ccurrentcontrolset)%5C%5Cservices%5C%5C.*%5C%5Cservicedll'%20OR%20LOWER(%22Registry%20Key%22)%20MATCHES%20'.*%5C%5Csystem%5C%5C(controlset001%7Ccontrolset002%7Ccurrentcontrolset)%5C%5Cservices%5C%5C.*%5C%5Cimagepath'|%5B%22LOWER(%5C%22Registry%20Key%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Csystem%5C%5C%5C%5C(controlset001%7Ccontrolset002%7Ccurrentcontrolset)%5C%5C%5C%5Cservices%5C%5C%5C%5C.*%5C%5C%5C%5Cservicedll'%20OR%20LOWER(%5C%22Registry%20Key%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Csystem%5C%5C%5C%5C(controlset001%7Ccontrolset002%7Ccurrentcontrolset)%5C%5C%5C%5Cservices%5C%5C%5C%5C.*%5C%5C%5C%5Cimagepath'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "3",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"3\", \"1\")' class='dynamic'>LOWER(&quot;Registry Value Data&quot;) MATCHES '.*\\\\windows\\\\system32\\\\drivers\\\\.*.sys' OR LOWER(&quot;Registry Value Data&quot;) MATCHES '.*\\\\sytemroot\\\\system32\\\\drivers\\\\.*.sys' OR LOWER(&quot;Registry Value Data&quot;) MATCHES '.*\\\\system32\\\\drivers\\\\usbstor'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Registry%20Value%20Data%22)%20MATCHES%20'.*%5C%5Cwindows%5C%5Csystem32%5C%5Cdrivers%5C%5C.*.sys'%20OR%20LOWER(%22Registry%20Value%20Data%22)%20MATCHES%20'.*%5C%5Csytemroot%5C%5Csystem32%5C%5Cdrivers%5C%5C.*.sys'%20OR%20LOWER(%22Registry%20Value%20Data%22)%20MATCHES%20'.*%5C%5Csystem32%5C%5Cdrivers%5C%5Cusbstor'|%5B%22LOWER(%5C%22Registry%20Value%20Data%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cwindows%5C%5C%5C%5Csystem32%5C%5C%5C%5Cdrivers%5C%5C%5C%5C.*.sys'%20OR%20LOWER(%5C%22Registry%20Value%20Data%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Csytemroot%5C%5C%5C%5Csystem32%5C%5C%5C%5Cdrivers%5C%5C%5C%5C.*.sys'%20OR%20LOWER(%5C%22Registry%20Value%20Data%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Csystem32%5C%5C%5C%5Cdrivers%5C%5C%5C%5Cusbstor'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>LOWER(&quot;Process File File Path&quot;) MATCHES '.*\\\\program files\\\\.*.exe' OR LOWER(&quot;Process File File Path&quot;) MATCHES '.*\\\\program files (x86)\\\\.*.exe' OR LOWER(&quot;Process File File Path&quot;) MATCHES '.*\\\\windows\\\\system32\\\\svchost\\.exe' OR LOWER(&quot;Process File File Path&quot;) MATCHES '.*\\\\windows\\\\system32\\\\tiworker\\.exe' OR LOWER(&quot;Process File File Path&quot;) MATCHES '.*\\\\windows\\\\system32\\\\drvinst\\.exe' OR LOWER(&quot;Process File File Path&quot;) MATCHES '.*\\\\windows\\\\system32\\\\services\\.exe' OR LOWER(&quot;Process File File Path&quot;) MATCHES '.*\\\\windows\\\\system32\\\\msiexec\\.exe' OR LOWER(&quot;Process File File Path&quot;) MATCHES '.*\\\\windows\\\\system32\\\\regsvr32\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Path%22)%20MATCHES%20'.*%5C%5Cprogram%20files%5C%5C.*.exe'%20OR%20LOWER(%22Process%20Path%22)%20MATCHES%20'.*%5C%5Cprogram%20files%20(x86)%5C%5C.*.exe'%20OR%20LOWER(%22Process%20Path%22)%20MATCHES%20'.*%5C%5Cwindows%5C%5Csystem32%5C%5Csvchost%5C.exe'%20OR%20LOWER(%22Process%20Path%22)%20MATCHES%20'.*%5C%5Cwindows%5C%5Csystem32%5C%5Ctiworker%5C.exe'%20OR%20LOWER(%22Process%20Path%22)%20MATCHES%20'.*%5C%5Cwindows%5C%5Csystem32%5C%5Cdrvinst%5C.exe'%20OR%20LOWER(%22Process%20Path%22)%20MATCHES%20'.*%5C%5Cwindows%5C%5Csystem32%5C%5Cservices%5C.exe'%20OR%20LOWER(%22Process%20Path%22)%20MATCHES%20'.*%5C%5Cwindows%5C%5Csystem32%5C%5Cmsiexec%5C.exe'%20OR%20LOWER(%22Process%20Path%22)%20MATCHES%20'.*%5C%5Cwindows%5C%5Csystem32%5C%5Cregsvr32%5C.exe'|%5B%22LOWER(%5C%22Process%20Path%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cprogram%20files%5C%5C%5C%5C.*.exe'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cprogram%20files%20(x86)%5C%5C%5C%5C.*.exe'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cwindows%5C%5C%5C%5Csystem32%5C%5C%5C%5Csvchost%5C%5C.exe'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cwindows%5C%5C%5C%5Csystem32%5C%5C%5C%5Ctiworker%5C%5C.exe'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cwindows%5C%5C%5C%5Csystem32%5C%5C%5C%5Cdrvinst%5C%5C.exe'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cwindows%5C%5C%5C%5Csystem32%5C%5C%5C%5Cservices%5C%5C.exe'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cwindows%5C%5C%5C%5Csystem32%5C%5C%5C%5Cmsiexec%5C%5C.exe'%20OR%20LOWER(%5C%22Process%20Path%5C%22)%20MATCHES%20'.*%5C%5C%5C%5Cwindows%5C%5C%5C%5Csystem32%5C%5C%5C%5Cregsvr32%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
