          "parameter": [
            {
              "id": "1",
              "value": "REPLACEALL('%5B%5C%2B%5C-%5Cs%5C.%5C%5E%5C%22%5C''%5D',%20DECODERS%3A%3ABASE64DECODE(%22Encoded%20Argument%22),%20'')%20MATCHES%20'((.*NewObject(System)%3FNetWebClient.*DownloadFile.*((StartProcess)%7C(shellexecute)%7C(win32_process)%7C(start)%7C(saps)).*)%7C(.*((iex)%7C(InvokeExpression)).*NewObject(System)%3FNetWebClient.*DownloadString.*)%7C(.*NewObject(System)%3FNetWebClient.*DownloadString.*((iex)%7C(InvokeExpression)).*)%7C(.*IEX.*%5C%5BSystemDiagnosticsProcess%5C%5D%5C%3A%5C%3AStart.*)%7C(.*StartBitsTransfer.*InvokeItem.*))'|%5B%22REPLACEALL('%5B%5C%5C%2B%5C%5C-%5C%5Cs%5C%5C.%5C%5C%5E%5C%5C%5C%22%5C%5C''%5D',%20DECODERS%3A%3ABASE64DECODE(%5C%22Encoded%20Argument%5C%22),%20'')%20MATCHES%20'((.*NewObject(System)%3FNetWebClient.*DownloadFile.*((StartProcess)%7C(shellexecute)%7C(win32_process)%7C(start)%7C(saps)).*)%7C(.*((iex)%7C(InvokeExpression)).*NewObject(System)%3FNetWebClient.*DownloadString.*)%7C(.*NewObject(System)%3FNetWebClient.*DownloadString.*((iex)%7C(InvokeExpression)).*)%7C(.*IEX.*%5C%5C%5BSystemDiagnosticsProcess%5C%5C%5D%5C%5C%3A%5C%5C%3AStart.*)%7C(.*StartBitsTransfer.*InvokeItem.*))'%22%5D"
