  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "EventCategory_Test",
            "uid": "1",
            "id": "21"
          },
          "text": [
            "when the event category for the event is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>System.Process Creation Success</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getCategories",
              "value": "8110"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>&quot;Parent Process Full Full Name&quot; MATCHES '(w3wp|php|php-cgi|nginx|httpd|caddy|ws_TomcatService|tomcat|UMWorkerProcess|java|javaw)\\.exe'</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "%22Parent%20Process%20Name%22%20MATCHES%20'(w3wp%7Cphp%7Cphp-cgi%7Cnginx%7Chttpd%7Ccaddy%7Cws_TomcatService%7Ctomcat%7CUMWorkerProcess%7Cjava%7Cjavaw)%5C.exe'|%5B%22%5C%22Parent%20Process%20Name%5C%22%20MATCHES%20'(w3wp%7Cphp%7Cphp-cgi%7Cnginx%7Chttpd%7Ccaddy%7Cws_TomcatService%7Ctomcat%7CUMWorkerProcess%7Cjava%7Cjavaw)%5C%5C.exe'%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "5",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>REFERENCESETCONTAINS('Windows Shell Processes', &quot;Process Full Full Name&quot;)</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "REFERENCESETCONTAINS('Windows%20Shell%20Processes'%2C%20%22Process%20Name%22)|%5B%22REFERENCESETCONTAINS('Windows%20Shell%20Processes'%2C%20%5C%22Process%20Name%5C%22)%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "4",
            "id": "320",
            "negate": "true"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>(&quot;Command&quot; LIKE '%Windows\\system32\\cmd.exe /c C:\\ManageEngine\\ADManager &quot;Plus\\ES\\bin\\elasticsearch.bat -Enode.name=RMP-NODE1 -pelasticsearch-pid.txt' OR (&quot;Command&quot; LIKE '%sc query%' AND &quot;Command&quot; LIKE '%ADManager Plus%'))</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(%22Command%22%20LIKE%20'%25Windows%5Csystem32%5Ccmd.exe%20%2Fc%20C%3A%5CManageEngine%5CADManager%20%22Plus%5CES%5Cbin%5Celasticsearch.bat%20-Enode.name%3DRMP-NODE1%20-pelasticsearch-pid.txt'%20OR%20(%22Command%22%20LIKE%20'%25sc%20query%25'%20AND%20%22Command%22%20LIKE%20'%25ADManager%20Plus%25'))|%5B%22(%5C%22Command%5C%22%20LIKE%20'%25Windows%5C%5Csystem32%5C%5Ccmd.exe%20%2Fc%20C%3A%5C%5CManageEngine%5C%5CADManager%20%5C%22Plus%5C%5CES%5C%5Cbin%5C%5Celasticsearch.bat%20-Enode.name%3DRMP-NODE1%20-pelasticsearch-pid.txt'%20OR%20(%5C%22Command%5C%22%20LIKE%20'%25sc%20query%25'%20AND%20%5C%22Command%5C%22%20LIKE%20'%25ADManager%20Plus%25'))%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
