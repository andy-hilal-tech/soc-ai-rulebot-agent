  "logic": [
    {
      "test": [
        {
          "_$": {
            "name": "DeviceTypeID_Test",
            "uid": "0",
            "id": "14"
          },
          "text": [
            "when the event(s) were detected by one or more of <a href='javascript:editParameter(\"0\", \"1\")' class='dynamic'>Microsoft Windows Security Event Log</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getDeviceTypeDescs",
              "value": "12"
            }
          ]
        },
        {
          "_$": {
            "name": "QID_Test",
            "uid": "1",
            "id": "19"
          },
          "text": [
            "when the event QID is one of the following <a href='javascript:editParameter(\"1\", \"1\")' class='dynamic'>(5001828) Process Create</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "method": "getQidsByLowLevelCategory",
              "value": "5001828"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "2",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>LOWER(&quot;Process Name&quot;) NOT IN ('smss.exe', 'wininit.exe', 'taskhost.exe', 'lsass.exe', 'winlogon.exe', 'explorer.exe', 'lsm.exe', 'svchost.exe', 'services.exe', 'csrss.exe')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "LOWER(%22Process%20Name%22)%20NOT%20IN%20('smss.exe'%2C%20'wininit.exe'%2C%20'taskhost.exe'%2C%20'lsass.exe'%2C%20'winlogon.exe'%2C%20'explorer.exe'%2C%20'lsm.exe'%2C%20'svchost.exe'%2C%20'services.exe'%2C%20'csrss.exe')|%5B%22LOWER(%5C%22Process%20Name%5C%22)%20NOT%20IN%20('smss.exe'%2C%20'wininit.exe'%2C%20'taskhost.exe'%2C%20'lsass.exe'%2C%20'winlogon.exe'%2C%20'explorer.exe'%2C%20'lsm.exe'%2C%20'svchost.exe'%2C%20'services.exe'%2C%20'csrss.exe')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        }
      ]
    }
  ],
