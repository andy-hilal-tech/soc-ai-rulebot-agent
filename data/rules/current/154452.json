        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "4",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"4\", \"1\")' class='dynamic'>Process Name (custom) is any of nslookup.exe</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Process NameEQanynslookup.exe"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "ArielFilterTest",
            "uid": "2",
            "id": "316"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"2\", \"1\")' class='dynamic'>Parent Process Name (custom) is any of [powershell.exe or pwsh.exe]</a>"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "Parent Process NameEQanypowershell.exe�pwsh.exe"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "AQL_Test",
            "uid": "5",
            "id": "320"
          },
          "text": [
            "when the event matches <a href='javascript:editParameter(\"5\", \"1\")' class='dynamic'>(LOWER(&quot;Command&quot;) LIKE '% -q=txt %' OR  LOWER(&quot;Command&quot;) LIKE '% -querytype=txt %')</a> AQL filter query"
          ],
          "parameter": [
            {
              "id": "1",
              "value": "(LOWER(%22Command%22)%20LIKE%20'%25%20-q%3Dtxt%20%25'%20OR%20%20LOWER(%22Command%22)%20LIKE%20'%25%20-querytype%3Dtxt%20%25')|%5B%22(LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20-q%3Dtxt%20%25'%20OR%20%20LOWER(%5C%22Command%5C%22)%20LIKE%20'%25%20-querytype%3Dtxt%20%25')%22%5D"
            },
            {
              "id": "2",
              "value": "events"
            }
          ]
        },
        {
          "_$": {
            "name": "functions.MatchCount",
            "uid": "3",
            "id": "300"
          },
          "text": [
